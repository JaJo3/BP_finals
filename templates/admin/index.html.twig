}

// Initialize circular progress rings (SVG)
try {
console.log('Initializing progress rings');
document.querySelectorAll('.progress-circle').forEach(function (el) {
try {
const value = parseFloat(el.getAttribute('data-value')) || 0;
const ring = el.querySelector('.ring');
const radius = parseFloat(ring.getAttribute('r')) || 30;
const circumference = 2 * Math.PI * radius;
ring.style.strokeDasharray = circumference;
const offset = circumference * (1 - Math.min(100, Math.max(0, value)) / 100);
ring.style.strokeDashoffset = offset;
// set inner number color for contrast on light background
const inner = el.querySelector('.progress-inner');
if (inner) {
inner.style.color = '#243b57';
inner.style.fontSize = '0.95rem';
}
} catch (e) {
