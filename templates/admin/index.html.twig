// Realtime updater and Extras toggle
(function () {
const API_ENDPOINT = '/api/admin/dashboard';

function applyRealtimeData(data) {
try {
if (! data) 
return;



// update simple keyed values
document.querySelectorAll('[data-dash-key]').forEach(function (el) {
const key = el.getAttribute('data-dash-key');
if (! key) 
return;



// look under data.totals first
if (data.totals && data.totals[key] !== undefined) {
const v = data.totals[key];
if (typeof v === 'number') {
el.textContent = '$' + Number(v).toLocaleString();
} else {
el.textContent = String(v);
}
}
});

// update sales chart if provided
if (window.salesChart && data.sales) {
const labels = data.sales.labels || window.salesChart.data.labels;
const values = data.sales.values || window.salesChart.data.datasets[0].data;
window.salesChart.data.labels = labels;
window.salesChart.data.datasets[0].data = values;
window.salesChart.update();
}
} catch (e) {
console.error('applyRealtimeData error', e);
}
}

async function fetchDashboardRealtime() {
try {
const res = await fetch(API_ENDPOINT, {cache: 'no-store'});
if (! res.ok) 
throw new Error('bad status');



const json = await res.json();
applyRealtimeData(json);
} catch (err) {
// fail silently; the page keeps working with static values
// console.debug('realtime fetch failed', err);
}
}

// start polling every 10s
fetchDashboardRealtime();
setInterval(fetchDashboardRealtime, 10000);

// extras toggle (hide/show optional cards)
const toggle = document.getElementById('toggleExtras');
const optionalCards = document.querySelectorAll('.optional-card');
function setExtrasVisible(visible) {
optionalCards.forEach(function (el) {
if (visible) {
el.classList.remove('hidden');
} else {
el.classList.add('hidden');
}
});
try {
localStorage.setItem('dashboard.showExtras', visible ? '1' : '0');
} catch (e) {}
if (toggle) 
toggle.textContent = visible ? 'Extras' : 'Extras';



}

// initialize from localStorage (default: visible)
try {
const stored = localStorage.getItem('dashboard.showExtras');
const visible = (stored === null) ? true : (stored === '1');
setExtrasVisible(visible);
} catch (e) {
setExtrasVisible(true);
}

if (toggle) {
toggle.addEventListener('click', function () {
try {
const curr = localStorage.getItem('dashboard.showExtras');
const visible = !(curr === null ? true : (curr === '1'));
setExtrasVisible(visible);
} catch (e) {
setExtrasVisible(false);
}
});
}
})();
// Best Selling range toggle (Today / Weekly / Monthly)
(function () {
const rangeButtons = document.querySelectorAll('[data-best-range]');
if (! rangeButtons.length) {
return;
}
function setRange(range) {
rangeButtons.forEach(function (btn) {
if (btn.getAttribute('data-best-range') === range) {
btn.classList.add('active');
} else {
btn.classList.remove('active');
}
});
['today', 'week', 'month'].forEach(function (key) {
const show = key === range;
const eventsBody = document.getElementById('best-events-' + key);
const ticketsBody = document.getElementById('best-tickets-' + key);
[eventsBody, ticketsBody].forEach(function (tbody) {
if (! tbody) 
return;



if (show) {
tbody.classList.remove('d-none');
} else {
tbody.classList.add('d-none');
}
});
});
}
rangeButtons.forEach(function (btn) {
btn.addEventListener('click', function () {
const range = btn.getAttribute('data-best-range') || 'today';
setRange(range);
});
});
// default
setRange('today');
})();
