]
};

const salesChart = new Chart(ctx, {
type: 'line',
data: data,
plugins: [
glowPlugin, indicatorPlugin, hoverLinePlugin
],
options: {
plugins: {
legend: {
display: true,
position: 'bottom',
labels: {
usePointStyle: true,
padding: 16,
color: labelGray
}
},
glowLinePlugin: {
blur: 16
},
tooltip: {
enabled: true,
intersect: false,
callbacks: {
label: function (ctx) {
const v = ctx.parsed && ctx.parsed.y ? ctx.parsed.y : ctx.raw;
const datasetLabel = ctx.dataset && ctx.dataset.label ? ctx.dataset.label + ': ' : '';
return datasetLabel + '$' + Number(v).toLocaleString();
},
title: function (items) {
if (! items || ! items.length) 
return '';



const item = items[0];
return labels[item.dataIndex] + ' · Revenue';
}
}
}
},
scales: {
y: {
min: 200000,
max: 1000000,
grid: {
color: secondaryColor.replace('0.8', '0.06') || 'rgba(148,163,184,0.06)',
drawBorder: false,
drawOnChartArea: true
},
ticks: {
color: labelGray,
callback: function (val) {
return(val / 1000) + 'k';
},
stepSize: 200000
}
},
x: {
grid: {
display: false
},
ticks: {
color: labelGray
}
}
},
interaction: {
mode: 'nearest',
intersect: false
},
maintainAspectRatio: false,
responsive: true,
elements: {
line: {
borderJoinStyle: 'round'
},
point: {
hoverRadius: 6
}
},
animation: {
duration: 900,
easing: 'cubicBezierEaseInOut'
}
}
});
// expose chart globally for realtime updates
try {
window.salesChart = salesChart;
} catch (e) { /* ignore if window not available */
}

// simple summary updater for UI (no backend binding yet)
function updateSummary() {
if (! summaryEl) 
return;



const eventLabel = eventFilterEl && eventFilterEl.options[eventFilterEl.selectedIndex] ? eventFilterEl.options[eventFilterEl.selectedIndex].text : 'All events';
const yearLabel = yearFilterEl && yearFilterEl.value ? yearFilterEl.value : 'This year';
let rangeLabel = 'This year';
if (dateFromEl && dateToEl && dateFromEl.value && dateToEl.value) {
rangeLabel = dateFromEl.value + ' to ' + dateToEl.value;
}
summaryEl.textContent = eventLabel + ' · ' + rangeLabel;
}[eventFilterEl, yearFilterEl, dateFromEl, dateToEl].forEach(function (el) {
if (! el) 
return;



el.addEventListener('change', updateSummary);
});
updateSummary();
}

// Pie chart
const pie = document.getElementById('pieChart');
