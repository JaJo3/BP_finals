const bodyColor = bodyStyles.getPropertyValue('color') || rootStyles.getPropertyValue('--bs-body-color') || '#15305A';
const secondaryColor = rootStyles.getPropertyValue('--bs-secondary-color') || 'rgba(148,163,184,0.8)';

// Golden gradient fill under the line
const gradient = ctx.createLinearGradient(0, 0, 0, 340);
gradient.addColorStop(0, 'rgba(249,178,51,0.28)');
gradient.addColorStop(0.5, 'rgba(249,178,51,0.10)');
gradient.addColorStop(1, 'rgba(249,178,51,0.00)');

const lineColor = rootStyles.getPropertyValue('--beatpass-yellow').trim() || '#F9B233';
const labelGray = secondaryColor.trim() || 'rgba(148,163,184,0.8)';

const labels = [
'Jan',
'Feb',
'Mar',
'Apr',
'May',
'Jun',
'Jul',
'Aug',
'Sep',
'Oct',
'Nov',
'Dec'
];
const currentYearValues = [
200000,
320000,
280000,
420000,
480000,
