];

// Glow plugin (subtle) preserved
const glowPlugin = {
id: 'glowLinePlugin',
beforeDatasetDraw(chart, args, options) {
const {ctx} = chart;
ctx.save();
ctx.shadowColor = 'rgba(249,178,51,0.85)';
ctx.shadowBlur = options.blur || 14;
},
afterDatasetDraw(chart, args, options) {
chart.ctx.restore();
}
};

// Indicator plugin: highlight October point and label
const indicatorPlugin = {
id: 'indicatorPlugin',
afterDraw(chart) {
const {ctx, scales} = chart;
const xScale = scales.x;
const yScale = scales.y;
if (! xScale || ! yScale) 
return;



const targetIndex = 9; // October
const x = xScale.getPixelForValue(labels[targetIndex]);
const y = yScale.getPixelForValue(currentYearValues[targetIndex]);
ctx.save();
// faint vertical marker for October
ctx.beginPath();
ctx.strokeStyle = secondaryColor.replace('0.8', '0.10') || 'rgba(148,163,184,0.10)';
ctx.lineWidth = 1;
ctx.moveTo(x, yScale.top);
ctx.lineTo(x, yScale.bottom);
ctx.stroke();
// outer white dot and inner gold dot
ctx.fillStyle = bodyColor;
ctx.beginPath();
ctx.arc(x, y, 5, 0, Math.PI * 2);
ctx.fill();
ctx.fillStyle = lineColor;
ctx.beginPath();
ctx.arc(x, y, 3, 0, Math.PI * 2);
ctx.fill();
// draw the month label more prominently at the bottom
ctx.fillStyle = bodyColor;
ctx.font = '600 12px sans-serif';
ctx.textAlign = 'center';
const labelY = chart.height - 8;
ctx.fillText(labels[targetIndex], x, labelY);
ctx.restore();
}
};

// Hover plugin: vertical line on hover and circular indicator
const hoverLinePlugin = {
id: 'hoverLine',
afterDraw(chart) {
const active = chart.tooltip && chart.tooltip.getActiveElements && chart.tooltip.getActiveElements();
if (! active || ! active.length) 
return;



const {ctx, scales} = chart;
const xScale = scales.x;
const yScale = scales.y;
const {datasetIndex, index} = active[0];
const meta = chart.getDatasetMeta(datasetIndex);
const el = meta.data[index];
if (! el) 
return;



const x = el.x;
const y = el.y;
ctx.save();
// vertical line
ctx.beginPath();
ctx.strokeStyle = secondaryColor.replace('0.8', '0.12') || 'rgba(148,163,184,0.12)';
ctx.lineWidth = 1;
ctx.moveTo(x, yScale.top);
ctx.lineTo(x, yScale.bottom);
ctx.stroke();
// outer white circle
ctx.fillStyle = bodyColor;
ctx.beginPath();
ctx.arc(x, y, 6, 0, Math.PI * 2);
ctx.fill();
// inner gold circle
ctx.fillStyle = lineColor;
ctx.beginPath();
ctx.arc(x, y, 3.5, 0, Math.PI * 2);
ctx.fill();
ctx.restore();
}
};

const data = {
