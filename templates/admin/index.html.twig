{% extends 'admin/base.html.twig' %}

{% block title %}BEATPASS Admin Dashboard
{% endblock %}

{% block body %}
	<style>
		/* Dashboard-specific CSS (color vars removed to use global theme from app.css) */

		.metric-card {
			border-radius: 12px;
			padding: 14px;
			color: #fff;
			box-shadow: 0 6px 18px rgba(21, 48, 90, 0.06);
			position: relative;
			overflow: hidden;
			transition: transform 220ms ease, box-shadow 220ms ease;
		}
		.metric-card:hover {
			transform: translateY(-6px);
			box-shadow: 0 18px 40px rgba(21, 48, 90, 0.18);
		}

		/* small decorative logo on metric cards (top-right) */
		.metric-card::after {
			content: '';
			position: absolute;
			right: 14px;
			top: 14px;
			width: 42px;
			height: 42px;
			border-radius: 10px;
			background-image: linear-gradient(135deg, rgba(255,255,255,0.06), rgba(255,255,255,0.02));
			box-shadow: inset 0 -6px 18px rgba(0, 0, 0, 0.06);
			opacity: 0.95;
			display: block;
			z-index: 1;
			backdrop-filter: blur(2px);
		}

		/* colorful gradients (use main brand vars) */
		.metric-pink {
			background: linear-gradient(135deg, rgba(232,62,140,0.95), rgba(249,178,51,0.85));
		}
		.metric-orange {
			background: linear-gradient(135deg, rgba(253,126,20,0.95), rgba(249,178,51,0.88));
		}
		.metric-purple {
			background: linear-gradient(135deg, #6f42c1, rgba(111,66,193,0.85));
		}
		.metric-teal {
			background: linear-gradient(135deg, #20C997, rgba(32,201,151,0.85));
		}

		.metric-body {
			display: flex;
			gap: 12px;
			align-items: center;
		}
		.metric-number {
			font-size: 1.25rem;
			font-weight: 700;
			color: #fff;
		}
		.metric-label {
			font-size: 0.85rem;
			color: rgba(255, 255, 255, 0.9);
		}

		.hero-card {
			border-radius: 12px;
			box-shadow: 0 10px 30px rgba(21, 48, 90, 0.06);
		}
		.hero-yellow {
			background: linear-gradient(180deg, rgba(249,178,51,0.08), rgba(249,178,51,0.02));
		}

		.card-blue {
			background: linear-gradient(180deg, rgba(21,48,90,0.05), rgba(21,48,90,0.02));
			border-radius: 10px;
		}

		.sales-card-dark {
			background: linear-gradient(180deg, rgba(21,48,90,0.06), rgba(21,48,90,0.02));
			border-radius: 10px;
		}

		.revenue-title {
			color: #ffffff;
			font-weight: 700;
		}
		.revenue-number {
			font-size: 1.5rem;
			font-weight: 800;
			color: #ffffff;
			margin-top: 8px;
		}

		.list-group-item {
			background: transparent;
			border: none;
			padding: 12px 0;
		}
		.amount-badge {
			color: var(--beatpass-blue);
			font-weight: 700;
		}
		.qty-pill {
			font-size: 12px;
			color: var(--muted);
		}

		.badge.bg-light.text-dark {
			background: #fff !important;
			color: var(--beatpass-blue) !important;
			border-radius: 6px;
			padding: 6px 10px;
			font-weight: 700;
		}
		.avatar.bg-secondary {
			background: linear-gradient(90deg,var(--beatpass-blue), var(--beatpass-yellow));
		}

		.chart-area {
			height: 320px;
		}
		.chart-area canvas {
			width: 100% !important;
			height: 100% !important;
			display: block;
		}

		/* align right column cards and ensure they fit without big gaps */
		.col-lg-4 .card {
			display: flex;
			flex-direction: column;
			justify-content: space-between;
		}
		.col-lg-4 .card .chart-area {
			height: 200px;
		}
		.chart-card {
			min-height: 360px;
		}
		@media(max-width: 991px) {
			/* collapse behavior for tablets */
			.col-lg-4 .card {
				margin-bottom: 12px;
			}
			.chart-card {
				min-height: 300px;
			}
		}

		/* optional cards (can be hidden via the Extras toggle) */
		.optional-card {
			transition: opacity 200ms ease, transform 220ms ease;
		}
		.optional-card.hidden {
			opacity: 0;
			transform: translateY(8px);
			height: 0;
			overflow: hidden;
			pointer-events: none;
			display: none;
		}

		/* small responsive tweaks */
		@media(max-width: 768px) {
			.metric-number {
				font-size: 1rem;
			}
		}

	</style>

	{# Top row: 4 metric cards (aligned to live data) #}
	<div class="row g-3 mb-4 top-metrics-row">
		<div class="col-6 col-md-3">
			<div class="metric-card metric-pink h-100">
				<div class="metric-body">
					<div class="metric-left metric-icon-box d-flex align-items-center justify-content-center rounded-3 bg-white bg-opacity-10">
						<i class="fas fa-users text-white fs-5"></i>
					</div>
					<div class="metric-right">
						<div class="metric-number">{{ data.stats.totalUsers|default(0)|number_format(0, '.', ',') }}</div>
						<div class="metric-label">Total Users</div>
					</div>
				</div>
			</div>
		</div>

		<div class="col-6 col-md-3">
			<div class="metric-card metric-orange h-100">
