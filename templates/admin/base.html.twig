<!DOCTYPE html>
<html>
	<head>
		<meta charset="UTF-8">
		<meta name="viewport" content="width=device-width, initial-scale=1.0">
		<title>
			{% block title %}ADMIN DASHBOARD
			{% endblock %}
		</title>
		<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.x/dist/css/bootstrap.min.css" rel="stylesheet">
		<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
		{% block stylesheets %}
			<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
			<link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
			{{ encore_entry_link_tags('app') }}
		{% endblock %}
		{% block javascripts_head %}
			{{ encore_entry_script_tags('app') }}
		{% endblock %}
	</head>
	<body class="admin bg-body text-body">
		<script>
			(function () {
try {
var s = localStorage.getItem('beatpass.admin.theme');
if (s === 'dark') {
document.documentElement.setAttribute('data-bs-theme', 'dark');
document.body.classList.add('dark-mode');
}
} catch (e) {}
})();
		</script>
		<div class="layout-container">
			<aside class="sidebar d-flex flex-column vh-100">
				<div class="brand text-center pt-0 pb-2">
					<a href="{{ path('app_dashboard') }}" class="d-block text-decoration-none">
						<img src="{{ asset('images/beatpass-logo.png') }}" alt="BeatPass Logo" class="img-fluid w-100 mx-auto d-block">
					</a>
				</div>
				<nav class="nav flex-column mt-1">
					{% if is_granted('ROLE_ADMIN') %}
						<a href="{{ path('app_dashboard') }}" class="nav-link d-flex align-items-center gap-2 px-3 py-2 mb-2 text-white {% if app.request.get('_route') == 'app_dashboard' %}active{% endif %}">
							<i class="fas fa-home"></i>
							<span>Dashboard</span>
						</a>
					{% endif %}

					{% if is_granted('ROLE_ADMIN') or is_granted('ROLE_STAFF') %}
						<a href="{{ path('app_event_index') }}" class="nav-link d-flex align-items-center gap-2 px-3 py-2 mb-2 text-white {% if app.request.get('_route') starts with 'app_event_' %}active{% endif %}">
							<i class="fas fa-calendar-alt"></i>
							<span>Events</span>
						</a>

						<a href="{{ path('admin_tickets') }}" class="nav-link d-flex align-items-center gap-2 px-3 py-2 mb-2 text-white {% if app.request.get('_route') starts with 'admin_tickets' or app.request.get('_route') starts with 'app_event_tickets_' %}active{% endif %}">
							<i class="fas fa-ticket-alt"></i>
							<span>Tickets</span>
						</a>

						<a href="{{ path('app_organizer_index') }}" class="nav-link d-flex align-items-center gap-2 px-3 py-2 mb-2 text-white {% if app.request.get('_route') starts with 'app_organizer_' %}active{% endif %}">
							<i class="fas fa-users"></i>
							<span>Organizers</span>
						</a>

						<a href="{{ path('app_transaction') }}" class="nav-link d-flex align-items-center gap-2 px-3 py-2 mb-2 text-white {% if app.request.get('_route') starts with 'app_transaction_' %}active{% endif %}">
							<i class="fas fa-receipt"></i>
							<span>Transactions</span>
						</a>
					{% endif %}

					{% if is_granted('ROLE_ADMIN') %}
						<a href="{{ path('app_user_index') }}" class="nav-link d-flex align-items-center gap-2 px-3 py-2 mb-2 text-white {% if app.request.get('_route') starts with 'app_user_' or app.request.get('_route') == 'app_user_index' %}active{% endif %}">
							<i class="fas fa-user"></i>
							<span>Users</span>
						</a>

						<a href="{{ path('app_activity_log_index') }}" class="nav-link d-flex align-items-center gap-2 px-3 py-2 mb-2 text-white {% if app.request.get('_route') starts with 'app_activity_log_' %}active{% endif %}">
							<i class="fas fa-history"></i>
							<span>Activity Logs</span>
						</a>
					{% endif %}
				</nav>

				<div class="mt-auto p-4 border-top border-light border-opacity-25">
					<div class="d-flex align-items-center gap-2 mb-3">
						{% if app.user is defined and app.user %}
							{% if app.user.profileImage is not empty %}
								<img src="{{ asset('uploads/profile/' ~ app.user.profileImage) }}" alt="Admin" class="rounded-circle img-fluid object-fit-cover flex-shrink-0" width="40" height="40">
							{% else %}
								<img src="{{ asset('images/default-avatar.png') }}" alt="Admin" class="rounded-circle img-fluid object-fit-cover flex-shrink-0" width="40" height="40">
							{% endif %}
							<div class="d-flex flex-column">
								<span class="text-light fw-semibold text-truncate">{{ (app.user.firstName is defined and app.user.firstName) ? (app.user.firstName ~ ' ' ~ (app.user.lastName|default(''))) : app.user.username }}</span>
								<small class="text-light opacity-75">Admin</small>
							</div>
						{% else %}
							<img src="{{ asset('images/default-avatar.png') }}" alt="Guest" class="rounded-circle img-fluid object-fit-cover flex-shrink-0" width="40" height="40">
							<div class="d-flex flex-column">
								<span class="text-light fw-semibold">Guest</span>
								<small class="text-light opacity-75">Guest</small>
							</div>
						{% endif %}
					</div>
					<a href="{{ path('app_logout') }}" class="btn btn-outline-light btn-sm w-100 py-2 mt-2">
						<i class="fas fa-sign-out-alt me-1"></i>Logout</a>
				</div>
			</aside>

			<div class="main-area w-100 d-flex flex-column bg-body">
				<nav id="adminTopNavbar" class="navbar navbar-expand-lg navbar-light bg-light py-2 px-3 rounded-bottom">
					<div class="container-fluid">
						<div class="d-flex justify-content-between align-items-center w-100">
							<div></div>
							<div class="d-flex align-items-center gap-2 gap-lg-3">
								<div class="d-flex align-items-center text-body-secondary small">
									<i class="fas fa-calendar-alt me-2"></i>
									<span id="adminCurrentDate">{{ "now"|date("F j, Y", "Asia/Manila") }}
										|
										{{ "now"|date("g:i A", "Asia/Manila") }}</span>
								</div>
								<div class="d-flex align-items-center gap-2 gap-lg-3">
									<button class="btn btn-sm btn-light border-0 position-relative header-icon" title="Notifications">
										<i class="fas fa-bell"></i>
										<span class="notif-dot"></span>
									</button>
									<button class="btn btn-sm btn-light border-0 header-icon d-none d-md-inline-flex" title="Messages">
										<i class="fas fa-envelope"></i>
									</button>
									<button id="themeToggle" class="btn btn-sm btn-light border-0 header-icon" type="button" title="Toggle dark mode" aria-label="Toggle dark mode">
										<i class="fas fa-moon"></i>
									</button>
									<div class="dropdown">
										<a href="#" class="d-flex align-items-center text-decoration-none user-link" id="userMenu" data-bs-toggle="dropdown" aria-expanded="false">
											{% if app.user is defined and app.user %}
												{% if app.user.profileImage is not empty %}
													<img src="{{ ('/uploads/profile/' ~ app.user.profileImage)|e }}" class="rounded-circle me-2 header-avatar" alt="{{ app.user.username|e }}">
												{% else %}
													<img src="{{ asset('images/default-avatar.png') }}" class="rounded-circle me-2 header-avatar" alt="{{ app.user.username|e }}">
												{% endif %}
												<i class="fas fa-caret-down ms-1 ms-md-2 small text-muted"></i>
											{% else %}
												<img src="https://via.placeholder.com/36" class="rounded-circle me-2 header-avatar" alt="user">
												<span class="d-none d-md-inline text-dark header-username">Guest</span>
												<i class="fas fa-caret-down ms-2 small text-muted"></i>
											{% endif %}
										</a>
										<ul class="dropdown-menu dropdown-menu-end" aria-labelledby="userMenu">
											<li>
												<a class="dropdown-item" href="{{ path('admin_profile') }}">Profile</a>
											</li>
											<li>
												<a class="dropdown-item" href="{{ path('app_logout') }}">Logout</a>
											</li>
										</ul>
									</div>
									<button class="btn btn-sm btn-light border-0 header-icon d-lg-none" id="sidebarToggle" title="Menu">
										<i class="fas fa-bars"></i>
									</button>
								</div>
							</div>
						</div>
					</nav>

					<main class="main-content px-4 py-4 bg-body flex-grow-1">
						{% for type, messages in app.flashes %}
							{% for msg in messages %}
								{% set bsClass = 'info' %}
								{% if type == 'success' %}
									{% set bsClass = 'success' %}
								{% elseif type == 'danger' or type == 'error' %}
									{% set bsClass = 'danger' %}
								{% elseif type == 'warning' %}
									{% set bsClass = 'warning' %}
								{% endif %}
								<div class="container-fluid mb-3">
									<div class="alert alert-{{ bsClass }} alert-dismissible fade show" role="alert">
										{{ msg }}
										<button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
									</div>
								</div>
							{% endfor %}
						{% endfor %}

						{% block body %}{% endblock %}
					</main>
				</div>
			</div>

			{% block javascripts %}
				<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
				<script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
				<script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
				<script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
				<script>
					// Admin theme (light / dark) toggle - uses Bootstrap data-bs-theme
(function () {
const STORAGE_KEY = 'beatpass.admin.theme';
const html = document.documentElement;
const body = document.body;
function applyTheme(theme) {
const isDark = theme === 'dark';
if (isDark) {
html.setAttribute('data-bs-theme', 'dark');
body.classList.add('dark-mode');
var topNav = document.getElementById('adminTopNavbar');
if (topNav) {
topNav.classList.remove('navbar-light', 'bg-light');
topNav.classList.add('navbar-dark', 'bg-dark');
}
} else {
html.removeAttribute('data-bs-theme');
body.classList.remove('dark-mode');
var topNav = document.getElementById('adminTopNavbar');
if (topNav) {
topNav.classList.remove('navbar-dark', 'bg-dark');
topNav.classList.add('navbar-light', 'bg-light');
}
}
}
try {
const saved = localStorage.getItem(STORAGE_KEY);
if (saved) {
applyTheme(saved);
}
} catch (e) {}

document.addEventListener('DOMContentLoaded', function () {
const toggle = document.getElementById('themeToggle');
if (! toggle) 
return;



const icon = toggle.querySelector('i');
if (icon && body.classList.contains('dark-mode')) {
icon.className = 'fas fa-sun';
}
toggle.addEventListener('click', function () {
const isDark = body.classList.contains('dark-mode');
const next = isDark ? 'light' : 'dark';
applyTheme(next);
try {
localStorage.setItem(STORAGE_KEY, next);
} catch (e) {}
if (icon) {
icon.className = next === 'dark' ? 'fas fa-sun' : 'fas fa-moon';
}
});
});
})();
				</script>
				<script>
					(function () {
const DEBOUNCE_MS = 700;
function attachPasswordToggles(root) {
root = root || document;
const inputs = root.querySelectorAll('input[type="password"]');
inputs.forEach(function (input) {
if (input.dataset.pwToggleAttached) 
return;



input.dataset.pwToggleAttached = '1';

// wrapper to allow absolute-positioned icon inside input
const wrapper = document.createElement('div');
wrapper.style.position = 'relative';
input.parentNode.insertBefore(wrapper, input);
wrapper.appendChild(input);

// ensure input has space on the right for icon
const computed = window.getComputedStyle(input);
input.style.paddingRight = '40px';

// create minimal eye button
const btn = document.createElement('button');
btn.type = 'button';
btn.setAttribute('aria-label', 'Toggle password visibility');
btn.style.position = 'absolute';
btn.style.top = '50%';
btn.style.transform = 'translateY(-50%)';
btn.style.right = '10px';
btn.style.border = 'none';
btn.style.background = 'transparent';
btn.style.padding = '4px';
btn.style.cursor = 'pointer';
btn.style.color = '#6c757d';
btn.style.fontSize = '0.95rem';
btn.innerHTML = '<i class="fas fa-eye"></i>';
btn.style.display = 'none';
wrapper.appendChild(btn);

let debounce = null;
function updateVisibility() {
if (input.value && input.value.length > 0) {
btn.style.display = 'block';
} else {
btn.style.display = 'none';
if (input.type !== 'password') {
input.type = 'password';
btn.innerHTML = '<i class="fas fa-eye"></i>';
}
}
}

input.addEventListener('input', function () {
if (debounce) 
clearTimeout(debounce);



debounce = setTimeout(updateVisibility, DEBOUNCE_MS);
});

// initial state
updateVisibility();

btn.addEventListener('click', function (e) {
e.preventDefault();
if (input.type === 'password') {
input.type = 'text';
btn.innerHTML = '<i class="fas fa-eye-slash"></i>';
} else {
input.type = 'password';
btn.innerHTML = '<i class="fas fa-eye"></i>';
}
});
});
}

document.addEventListener('DOMContentLoaded', function () {
attachPasswordToggles(document);
});
// Re-run on Turbo navigations and frame loads so dynamically replaced content gets toggles attached
document.addEventListener('turbo:load', function (e) {
attachPasswordToggles(e.target || document);
document.dispatchEvent(new Event('app:load'));
});
document.addEventListener('turbo:frame-load', function (e) {
attachPasswordToggles(e.target || document);
document.dispatchEvent(new Event('app:load'));
});
})();
				</script>
			{% endblock %}
		</body>
	</body>
</html>
