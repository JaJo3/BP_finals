<!DOCTYPE html>
<html>
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}BEATPASS Admin{% endblock %}</title>
        <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.x/dist/css/bootstrap.min.css" rel="stylesheet">
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.2/css/all.min.css">
        {% block stylesheets %}
            {# DataTables CSS (CDN) for table styling + responsive support #}
            <link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/jquery.dataTables.min.css">
            <link rel="stylesheet" href="https://cdn.datatables.net/responsive/2.5.0/css/responsive.dataTables.min.css">
            {{ encore_entry_link_tags('app') }}
        {% endblock %}
    </head>
    <body class="admin">
        <div class="layout-container">
            <aside class="sidebar">
                <div class="brand">
                    <span>BEATPASS Admin</span>
                </div>
                <nav>
                    <a href="{{ path('app_dashboard') }}" 
                       class="nav-link {% if app.request.get('_route') == 'app_dashboard' %}active{% endif %}">
                        <i class="fas fa-home"></i>
                        <span>Dashboard</span>
                    </a>
                    
                    <a href="{{ path('app_event_index') }}" 
                       class="nav-link {% if app.request.get('_route') starts with 'app_event_' %}active{% endif %}">
                        <i class="fas fa-calendar-alt"></i>
                        <span>Events</span>
                    </a>
                    
                    <a href="{{ path('admin_tickets') }}" 
                       class="nav-link {% if app.request.get('_route') starts with 'admin_tickets' or app.request.get('_route') starts with 'app_event_tickets_' %}active{% endif %}">
                        <i class="fas fa-ticket-alt"></i>
                        <span>Tickets</span>
                    </a>
                    
                    <a href="{{ path('app_organizer_index') }}" 
                       class="nav-link {% if app.request.get('_route') starts with 'app_organizer_' %}active{% endif %}">
                        <i class="fas fa-users"></i>
                        <span>Organizers</span>
                    </a>
                </nav>
            </aside>

            <main class="main-content">
                {% block body %}{% endblock %}
            </main>
        </div>

        {% block javascripts %}
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
            {# jQuery + DataTables (loaded before app bundle so initialization in templates works) #}
            <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>
            <script src="https://cdn.datatables.net/1.13.6/js/jquery.dataTables.min.js"></script>
            <script src="https://cdn.datatables.net/responsive/2.5.0/js/dataTables.responsive.min.js"></script>
            {{ encore_entry_script_tags('app') }}
        {% endblock %}
    </body>
</html>
