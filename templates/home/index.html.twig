{% extends 'base.html.twig' %}

{% block title %}BEATPASS - Home
{% endblock %}

{% block body %}

	<!-- Navbar -->
	<nav class="navbar">
		<a href="#" class="logo">🎵 BeatPass</a>
		<ul>
			<li>
				<a href="#">Home</a>
			</li>
			<li>
				<a href="#">Events</a>
			</li>
			<li>
				<a href="#">About</a>
			</li>
			<li>
				<a href="#">Contact</a>
			</li>
			<li>
				<a href="#">Login/Signup</a>
			</li>
		</ul>
		<a href="#" class="btn-tickets">Find Tickets</a>
	</nav>

	<section class="hero">
		<div class="hero-content">
			<h1>Your Access to Live Music</h1>
			<p>Experience Unforgettable Beats</p>
			<div class="search-bar">
				<input type="text" placeholder="Search by Artist, Venue, or City">
				<button>Search</button>
			</div>
		</div>
	</section>

	<section class="events">
		<div class="card">
			<img src="/images/concert.jpg" alt="Concerts">
			<h3>Concerts</h3>
			<p>Find the hottest concerts around you.</p>
			<a href="#">Explore</a>
		</div>
		<div class="card">
			<img src="/images/festival.jpg" alt="Festivals">
			<h3>Festivals</h3>
			<p>Join unforgettable music festivals worldwide.</p>
			<a href="#">Explore</a>
		</div>
		<div class="card">
			<img src="/images/discover.jpg" alt="Discover">
			<h3>Discover</h3>
			<p>Discover new artists and unique events.</p>
			<a href="#">Explore</a>
		</div>
	</section>

	<footer>
		<p>© 2025 BeatPass. All Rights Reserved.</p>
	</footer>
{% endblock %}
