<div
	class="action-button">
	<!-- Delete Button -->
	<button type="button" class="btn p-0 d-flex align-items-center justify-content-center rounded-3" style="width:32px;height:32px;background-color:rgba(220,53,69,0.1);color:#dc3545;" data-bs-toggle="modal" data-bs-target="#deleteTicketModal{{ ticket.id }}" title="Delete">
		<i class="fas fa-trash fa-sm"></i>
	</button>

	<!-- Delete Confirmation Modal -->
	<div class="modal fade" id="deleteTicketModal{{ ticket.id }}" tabindex="-1" aria-labelledby="deleteModalLabel{{ ticket.id }}" aria-hidden="true">
		<div class="modal-dialog modal-dialog-centered">
			<div class="modal-content">
				<div class="modal-header" style="background-color: #1A3D7C; color: white">
					<h5 class="modal-title" id="deleteModalLabel{{ ticket.id }}">
						<i class="fas fa-exclamation-triangle me-2"></i>
						Confirm Delete
					</h5>
					<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
				</div>
				<div class="modal-body p-4">
					<div class="text-center mb-3">
						<i class="fas fa-trash-alt fa-3x text-danger mb-3"></i>
						<h5>Delete Ticket</h5>
						<p class="text-muted">
							Are you sure you want to delete this ticket? 
														                            This action cannot be undone.
						</p>
					</div>
					<div class="ticket-info p-3 bg-light rounded">
						<p class="mb-1">
							<strong>Event:</strong>
							{{ ticket.event.eventName }}</p>
						<p class="mb-1">
							<strong>Price:</strong>
							₱{{ ticket.price|number_format(2, '.', ',') }}</p>
						<p class="mb-0">
							<strong>Type:</strong>
							{{ ticket.ticketType }}</p>
					</div>
				</div>
				<div class="modal-footer">
					<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">
						<i class="fas fa-times me-2"></i>Cancel
					</button>
					<form method="post" action="{{ path('admin_ticket_delete', {'id': ticket.id}) }}" onsubmit="return confirm('Are you sure you want to delete this ticket?');" style="display: inline;">
						<input type="hidden" name="_token" value="{{ csrf_token('delete' ~ ticket.id) }}">
						<button type="submit" class="btn btn-sm btn-danger">
							<i class="fas fa-trash"></i>
						</button>
					</form>
				</div>
			</div>
		</div>
	</div>
</div>
