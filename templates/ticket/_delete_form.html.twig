<div class="action-button">
     <!-- Delete Button -->
    <button type="button" class="btn btn-sm" data-bs-toggle="modal" data-bs-target="#deleteModal{{ ticket.id }}" style="background: linear-gradient(135deg, #dc3545 0%, #c82333 100%); color: white; border: none; border-radius: 8px; padding: 8px 12px;">
    <i class="fas fa-trash"></i>
</button>

    <!-- Delete Confirmation Modal -->
    <div class="modal fade" 
         id="deleteModal{{ ticket.id }}" 
         tabindex="-1" 
         aria-labelledby="deleteModalLabel{{ ticket.id }}" 
         aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header" style="background-color: #1A3D7C; color: white">
                    <h5 class="modal-title" id="deleteModalLabel{{ ticket.id }}">
                        <i class="fas fa-exclamation-triangle me-2"></i>
                        Confirm Delete
                    </h5>
                    <button type="button" 
                            class="btn-close btn-close-white" 
                            data-bs-dismiss="modal" 
                            aria-label="Close">
                    </button>
                </div>
                <div class="modal-body p-4">
                    <div class="text-center mb-3">
                        <i class="fas fa-trash-alt fa-3x text-danger mb-3"></i>
                        <h5>Delete Ticket</h5>
                        <p class="text-muted">
                            Are you sure you want to delete this ticket? 
                            This action cannot be undone.
                        </p>
                    </div>
                    <div class="ticket-info p-3 bg-light rounded">
                        <p class="mb-1"><strong>Event:</strong> {{ ticket.event.eventName }}</p>
                        <p class="mb-1"><strong>Price:</strong> ₱{{ ticket.price|number_format(2, '.', ',') }}</p>
                        <p class="mb-0"><strong>Type:</strong> {{ ticket.ticketType }}</p>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" 
                            class="btn btn-outline-secondary" 
                            data-bs-dismiss="modal">
                        <i class="fas fa-times me-2"></i>Cancel
                    </button>
                    <form method="post" 
                          action="{{ path('admin_ticket_delete', {'id': ticket.id}) }}"
                          onsubmit="return confirm('Are you sure you want to delete this ticket?');"
                          style="display: inline;">
                        <input type="hidden" 
                               name="_token" 
                               value="{{ csrf_token('delete' ~ ticket.id) }}">
                        <button type="submit" class="btn btn-sm btn-danger">
                            <i class="fas fa-trash"></i>
                        </button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .action-button {
        display: inline-block;
    }
    .action-button .btn {
        padding: 0.375rem 0.75rem;
    }
    .modal-body .fas.fa-trash-alt {
        color: #dc3545;
    }
    .ticket-info {
        background-color: rgba(26, 61, 124, 0.05);
        border-left: 4px solid #1A3D7C;
    }
</style> 
