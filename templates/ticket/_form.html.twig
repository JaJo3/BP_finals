{{ form_start(form, {'attr': {'class': 'p-4'}}) }}

{# Render global form errors so Turbo 422 responses show validation messages #}
{% if form.vars.errors|length > 0 %}
    <div class="alert alert-danger">
        {{ form_errors(form) }}
    </div>
{% endif %}

<!-- Combined Ticket Card: Reference + Details -->
<div class="card shadow-sm mb-4 border-0">
    <div class="card-header text-white d-flex align-items-center" style="background-color: #1A3D7C;">
        <i class="fas fa-tags me-2" style="color: #F9B233;"></i>
        <h6 class="m-0 fw-bold">Ticket Tiers Reference</h6>
    </div>

    <div class="card-body p-4">
        <!-- Reference table -->
        <div class="table-responsive mb-4">
            <table class="table table-bordered table-hover align-middle">
                <thead style="background-color: #F9B233; color: #1A3D7C;">
                    <tr>
                        <th width="15%">Tier Type</th>
                        <th width="60%">Benefits</th>
                        <th width="25%">Price Range</th>
                    </tr>
                </thead>
                <tbody>
                    <tr>
                        <td>
                            <span class="badge bg-secondary px-3 py-2">Regular</span>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-2">
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Standard seating</div>
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Basic amenities</div>
                            </div>
                        </td>
                        <td class="fw-bold" style="color: #1A3D7C;">5,000 - 10,000</td>
                    </tr>
                    <tr>
                        <td>
                            <span class="badge text-bg-dark px-3 py-2">VIP</span>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-2">
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Premium seating</div>
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Event merchandise</div>
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Priority entrance</div>
                            </div>
                        </td>
                        <td class="fw-bold" style="color: #1A3D7C;">10,000 - 15,000</td>
                    </tr>
                    <tr>
                        <td>
                            <span class="badge text-dark px-3 py-2" style="background-color: #F9B233;">VVIP</span>
                        </td>
                        <td>
                            <div class="d-flex flex-column gap-2">
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Best seating</div>
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Meet & Greet passes</div>
                                <div>
                                    <i class="fas fa-check-circle text-success me-2"></i>Exclusive merchandise</div>
                            </div>
                        </td>
                        <td class="fw-bold" style="color: #1A3D7C;">20,000 - 30,000</td>
                    </tr>
                </tbody>
            </table>
        </div>

        <!-- Prominent subheader for details -->
        <div class="mb-4">
            <h5 class="m-0 fw-bold" style="color: #1A3D7C;"><i class="fas fa-edit me-2" style="color: #F9B233;"></i>Ticket Details</h5>
        </div>

        <div class="row g-4">
            <!-- Event Selection -->
            <div class="col-12">
                <div class="form-group">
                    {{ form_label(form.event, null, {
                        'label_attr': {
                            'class': 'form-label fw-semibold mb-2',
                            'style': 'color:#1A3D7C;'
                        }
                    }) }}
                    {{ form_widget(form.event, {
                        'attr': {
                            'class': 'form-select',
                            'style': 'border: 2px solid #e9ecef; border-radius: 8px; padding: 12px;'
                        }
                    }) }}
                    {{ form_errors(form.event) }}
                </div>
            </div>

            <!-- Ticket Type and Price -->
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.ticketType, null, {
                        'label_attr': {
                            'class': 'form-label fw-semibold mb-2',
                            'style': 'color:#1A3D7C;'
                        }
                    }) }}
                    {{ form_widget(form.ticketType, {
                        'attr': {
                            'class': 'form-select',
                            'style': 'border: 2px solid #e9ecef; border-radius: 8px; padding: 12px;'
                        }
                    }) }}
                    {{ form_errors(form.ticketType) }}
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.price, null, {
                        'label_attr': {
                            'class': 'form-label fw-semibold mb-2',
                            'style': 'color:#1A3D7C;'
                        }
                    }) }}
                    <div class="input-group">
                        {{ form_widget(form.price, {
                            'money_pattern': '{{ widget }}',
                            'attr': {
                                'class': 'form-control',
                                'placeholder': 'Enter price',
                                'style': 'border: 2px solid #e9ecef; border-radius: 8px; padding: 12px;'
                            }
                        }) }}
                        {{ form_errors(form.price) }}
                    </div>
                </div>
            </div>

            <!-- Quantity and Status -->
            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.quantity, null, {
                        'label_attr': {
                            'class': 'form-label fw-semibold mb-2',
                            'style': 'color:#1A3D7C;'
                        }
                    }) }}
                    {{ form_widget(form.quantity, {
                        'attr': {
                            'class': 'form-control',
                            'style': 'border: 2px solid #e9ecef; border-radius: 8px; padding: 12px;'
                        }
                    }) }}
                    {{ form_errors(form.quantity) }}
                </div>
            </div>

            <div class="col-md-6">
                <div class="form-group">
                    {{ form_label(form.status, null, {
                        'label_attr': {
                            'class': 'form-label fw-semibold mb-2',
                            'style': 'color:#1A3D7C;'
                        }
                    }) }}
                    {{ form_widget(form.status, {
                        'attr': {
                            'class': 'form-select',
                            'style': 'border: 2px solid #e9ecef; border-radius: 8px; padding: 12px;'
                        },
                        'choice_attr': {
                            'Upcoming': {'style': 'background-color: #F9B233; color: #1A3D7C; font-weight: 500;'},
                            'Ongoing': {'style': 'background-color: #20c997; color: white; font-weight: 500;'},
                            'Completed': {'style': 'background-color: #6c757d; color: white; font-weight: 500;'},
                            'Cancelled': {'style': 'background-color: #dc3545; color: white; font-weight: 500;'}
                        }
                    }) }}
                    {{ form_errors(form.status) }}
                </div>
            </div>
        </div>
    </div>

    <div class="card-footer bg-light p-4" style="border-top: 1px solid #e9ecef;">
        <div class="d-flex justify-content-end gap-3">
            <a href="{{ path('admin_tickets') }}" class="btn btn-outline-secondary" style="border-radius: 8px; padding: 12px 24px; font-weight: 500;">
                <i class="fas fa-times me-2"></i>Cancel
            </a>
            <button type="submit" class="btn" style="background: linear-gradient(135deg, #1A3D7C 0%, #152E54 100%); color: white; border: none; border-radius: 8px; padding: 12px 24px; font-weight: 600;">
                <i class="fas fa-save me-2" style="color: #F9B233;"></i>
                {{ button_label|default('Save Ticket') }}
            </button>
        </div>
    </div>
</div>

{{ form_end(form) }}
