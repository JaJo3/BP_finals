{% extends 'admin/base.html.twig' %}
{% block title %}Activity Logs
{% endblock %}

{% block body %}
	{% set createCount = 0 %}
	{% set updateCount = 0 %}
	{% set deleteCount = 0 %}
	{% set loginCount = 0 %}
	{% set logoutCount = 0 %}
	{% set otherCount = 0 %}
	{% for l in logs|default([]) %}
		{% if l.action == 'Create' %}
			{% set createCount = createCount + 1 %}
		{% elseif l.action == 'Update' %}
			{% set updateCount = updateCount + 1 %}
		{% elseif l.action == 'Delete' %}
			{% set deleteCount = deleteCount + 1 %}
		{% elseif l.action == 'Login' %}
			{% set loginCount = loginCount + 1 %}
		{% elseif l.action == 'Logout' %}
			{% set logoutCount = logoutCount + 1 %}
		{% else %}
			{% set otherCount = otherCount + 1 %}
		{% endif %}
	{% endfor %}

	<div class="content-wrapper content-wrapper--logs pt-0">
		<div class="d-flex justify-content-between align-items-center mb-2">
			<h1 class="h5 mb-0" style="color: #1A3D7C;">
				<i class="fas fa-history me-2 text-warning"></i>Activity Logs
			</h1>
		</div>

		<div class="card shadow-sm">
			<div class="card-header d-flex justify-content-between align-items-center py-3">
				<div class="d-flex align-items-center">
					<h3 class="card-title mb-0" style="font-weight: 600; font-size: 1rem;">
						<i class="fas fa-list me-2" style="color: #F9B233;"></i>All Activity Logs
					</h3>
				</div>
				<span class="badge bg-warning text-dark fw-bold">{{ logs|length }}
					items</span>
			</div>
		</div>

		<div class="px-3 py-2 d-flex flex-wrap align-items-center justify-content-between gap-2 bg-light border-bottom">
			<div class="beatpass-pillbar d-flex flex-wrap gap-2">
				<span class="beatpass-pill" style="background: rgba(26,61,124,0.10); color: #1A3D7C; border-color: rgba(26,61,124,0.12); font-weight: 500;">
					<i class="fas fa-plus-circle me-1" style="opacity: 0.7;"></i>Create:
					{{ createCount }}
				</span>
				<span class="beatpass-pill" style="background: rgba(26,61,124,0.10); color: #1A3D7C; border-color: rgba(26,61,124,0.12); font-weight: 500;">
					<i class="fas fa-edit me-1" style="opacity: 0.7;"></i>Update:
					{{ updateCount }}
				</span>
				<span class="beatpass-pill" style="background: rgba(26,61,124,0.10); color: #1A3D7C; border-color: rgba(26,61,124,0.12); font-weight: 500;">
					<i class="fas fa-trash-alt me-1" style="opacity: 0.7;"></i>Delete:
					{{ deleteCount }}
				</span>
				<span class="beatpass-pill" style="background: rgba(26,61,124,0.10); color: #1A3D7C; border-color: rgba(26,61,124,0.12); font-weight: 500;">
					<i class="fas fa-sign-in-alt me-1" style="opacity: 0.7;"></i>Login:
					{{ loginCount }}
				</span>
				<span class="beatpass-pill" style="background: rgba(26,61,124,0.10); color: #1A3D7C; border-color: rgba(26,61,124,0.12); font-weight: 500;">
					<i class="fas fa-sign-out-alt me-1" style="opacity: 0.7;"></i>Logout:
					{{ logoutCount }}
				</span>
				<span class="beatpass-pill" style="background: rgba(26,61,124,0.10); color: #1A3D7C; border-color: rgba(26,61,124,0.12); font-weight: 500;">
					<i class="fas fa-ellipsis-h me-1" style="opacity: 0.7;"></i>Other:
					{{ otherCount }}
				</span>
			</div>

			<div class="collapse" id="logsFilterCollapse">
				<div class="px-3 pb-3">
					<form method="get" class="row g-3 align-items-end">
						<div class="col-md-3">
							<label for="filterUser" class="form-label small text-muted mb-1">User</label>
							<input type="text" id="filterUser" name="user" class="form-control form-control-sm" placeholder="Search user..." value="{{ filters.user|default('') }}">
						</div>
						<div class="col-md-3">
							<label for="filterAction" class="form-label small text-muted mb-1">Action</label>
							<select id="filterAction" name="action" class="form-select form-select-sm">
								<option value="">All Actions</option>
								{% for action in availableActions %}
									<option value="{{ action }}" {% if filters.action == action %} selected {% endif %}>{{ action }}</option>
								{% endfor %}
							</select>
						</div>
						<div class="col-md-2">
							<label for="filterDateFrom" class="form-label small text-muted mb-1">From</label>
							<input type="date" id="filterDateFrom" name="dateFrom" class="form-control form-control-sm" value="{{ filters.dateFrom|default('') }}">
						</div>
						<div class="col-md-2">
							<label for="filterDateTo" class="form-label small text-muted mb-1">To</label>
							<input type="date" id="filterDateTo" name="dateTo" class="form-control form-control-sm" value="{{ filters.dateTo|default('') }}">
						</div>
						<div class="col-md-2 d-flex gap-2">
							<button type="submit" class="btn btn-sm w-100" style="background-color: #1A3D7C; color: white; border: none;">
								<i class="fas fa-search me-1"></i>Apply
							</button>
							{% if filters.user or filters.action or filters.dateFrom or filters.dateTo %}
								<a href="{{ path('app_activity_log_index') }}" class="btn btn-outline-secondary btn-sm w-100">
									<i class="fas fa-redo me-1"></i>Reset
								</a>
							{% endif %}
						</div>
					</form>
				</div>
			</div>

			<!-- Show Actions Toggle -->
			<div class="d-flex flex-wrap align-items-center justify-content-end gap-2 px-3 py-2 bg-light border-bottom">
				<div class="form-check form-switch m-0" style="padding-left: 2.5em;">
					<input class="form-check-input" type="checkbox" id="toggleActionsSwitch" style="width: 2.5em; height: 1.25em; cursor: pointer;">
					<label class="form-check-label small text-muted ms-1" for="toggleActionsSwitch" style="cursor: pointer;">Show actions</label>
				</div>
			</div>

			<div class="card-body p-0">
				<div class="table-responsive">
					<table id="activityLogsTable" class="table table-sm table-hover beatpass-table mb-0">
						<thead class="table-light">
							<tr>
								<th class="text-nowrap small fw-semibold text-uppercase py-1 px-2">User</th>
								<th class="text-nowrap small fw-semibold text-uppercase py-1 px-2">Action</th>
								<th class="text-nowrap small fw-semibold text-uppercase py-1 px-2">Module</th>
								<th class="text-nowrap small fw-semibold text-uppercase py-1 px-2">Date & Time</th>
								<th class="text-nowrap small fw-semibold text-uppercase py-1 px-2">Status</th>
								<th class="actions text-center text-nowrap small fw-semibold text-uppercase py-1 px-2 d-none">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% if logs|length > 0 %}
								{% for log in logs %}
									<tr>
										<td class="align-middle py-1 px-2">
											<div class="d-flex align-items-center gap-2">
												<span class="fw-semibold small" style="color: #1A3D7C;">{{ log.user.firstName|default(log.user.username) }}</span>
												{% set roles = log.user.getRoles() %}
												{% if 'ROLE_ADMIN' in roles %}
													<span class="badge rounded-pill bg-primary bg-opacity-10 text-primary small fw-semibold px-2 py-1" style="font-size: 0.65rem;">Admin</span>
												{% elseif 'ROLE_STAFF' in roles %}
													<span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary small fw-semibold px-2 py-1" style="font-size: 0.65rem;">Staff</span>
												{% endif %}
											</div>
										</td>
										<td class="align-middle py-1 px-2">
											{% if log.action == 'Create' %}
												<div class="small fw-semibold" style="color: #15305A;">
													<i class="fas fa-plus-circle me-1"></i>Create</div>
											{% elseif log.action == 'Update' %}
												<div class="small fw-semibold" style="color: #15305A;">
													<i class="fas fa-edit me-1"></i>Update</div>
											{% elseif log.action == 'Delete' %}
												<div class="small fw-semibold" style="color: #15305A;">
													<i class="fas fa-trash-alt me-1"></i>Delete</div>
											{% elseif log.action == 'Login' %}
												<div class="small fw-semibold" style="color: #15305A;">
													<i class="fas fa-sign-in-alt me-1"></i>Login</div>
											{% elseif log.action == 'Logout' %}
												<div class="small fw-semibold" style="color: #15305A;">
													<i class="fas fa-sign-out-alt me-1"></i>Logout</div>
											{% else %}
												<div class="small fw-semibold" style="color: #15305A;">{{ log.action }}</div>
											{% endif %}
										</td>
										<td class="align-middle py-1 px-2">
											{% if log.entityType %}
												<span class="badge rounded-pill py-1 px-2 small" color: white;">{{ log.entityType }}</span>
											{% else %}
												<span class="text-muted">—</span>
											{% endif %}
										</td>
										<td class="text-nowrap align-middle py-1 px-2">
											<small class="text-muted">{{ log.createdAt|date('M d, Y h:i A') }}</small>
										</td>
										<td class="align-middle py-1 px-2">
											{% if log.action == 'Create' %}
												<span class="badge rounded-pill bg-success bg-opacity-10 text-success small fw-semibold px-3 py-2">Completed</span>
											{% elseif log.action == 'Update' %}
												<span class="badge rounded-pill bg-info bg-opacity-10 text-info small fw-semibold px-3 py-2">Updated</span>
											{% elseif log.action == 'Delete' %}
												<span class="badge rounded-pill bg-danger bg-opacity-10 text-danger small fw-semibold px-3 py-2">Deleted</span>
											{% elseif log.action == 'Login' %}
												<span class="badge rounded-pill bg-primary bg-opacity-10 text-primary small fw-semibold px-3 py-2">Login</span>
											{% elseif log.action == 'Logout' %}
												<span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary small fw-semibold px-3 py-2">Logout</span>
											{% else %}
												<span class="badge rounded-pill bg-secondary bg-opacity-10 text-secondary small fw-semibold px-3 py-2">{{ log.action }}</span>
											{% endif %}
										</td>
										<td class="actions text-center align-middle py-1 px-2 d-none">
											<div class="d-inline-flex align-items-center gap-2">
												<a href="{{ path('app_activity_log_show', {'id': log.id}) }}" class="btn p-0 d-flex align-items-center justify-content-center rounded-3" title="View Details" style="width:32px;height:32px;background-color:rgba(26,61,124,0.1);color:#1A3D7C;">
													<i class="fas fa-eye fa-sm"></i>
												</a>
											</div>
										</td>
									</tr>
								{% endfor %}
							{% else %}
								<tr>
									<td colspan="6" class="text-center py-4">
										<div class="text-muted">
											<div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 64px; height: 64px;">
												<i class="fas fa-inbox fa-2x text-primary opacity-50"></i>
											</div>
											<h6 class="text-primary fw-semibold mb-1">No activity logs found</h6>
											<p class="text-muted small mb-0">Try adjusting your filters.</p>
										</div>
									</td>
								</tr>
							{% endif %}
						</tbody>
					</table>
				</div>
			</div>
		</div>
	</div>
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		(function ($) {
function initActivityLogsTable() {
var tableBody = $('#activityLogsTable tbody');
var hasDataRows = tableBody.find('tr').length > 0 && ! tableBody.find('tr').first().find('td').attr('colspan');
if (! hasDataRows) 
return;



if ($.fn.DataTable.isDataTable('#activityLogsTable')) {
$('#activityLogsTable').DataTable().destroy();
}

var dt = $('#activityLogsTable').DataTable({
responsive: true,
dom: "<'row g-0'<'col-auto'l><'col-auto ms-auto'f>><'row'<'col-sm-12'tr>><'row g-0 small'<'col-auto'i><'col-auto ms-auto'p>>",
pageLength: 10,
lengthMenu: [
[
10, 25, 50, -1
],
[
10, 25, 50, 'All'
]
],
autoWidth: true,
scrollX: false,
language: {
search: '',
searchPlaceholder: 'Search logs...'
},
columnDefs: [
{
orderable: false,
searchable: false,
targets: -1
}
]
});

function setActionsVisible(visible) {
$('#activityLogsTable thead th.actions, #activityLogsTable tbody td.actions').toggleClass('d-none', ! visible);
try {
localStorage.setItem('activityLogs.showActions', visible ? '1' : '0');
} catch (e) {}
}

try {
var stored = localStorage.getItem('activityLogs.showActions');
var initialVisible = stored === '1';
$('#toggleActionsSwitch').prop('checked', initialVisible);
setActionsVisible(initialVisible);
} catch (e) {
setActionsVisible(false);
}

$('#toggleActionsSwitch').off('change').on('change', function () {
setActionsVisible($(this).is(':checked'));
});

dt.on('draw.dt responsive-display.dt responsive-resize.dt', function () {
setActionsVisible($('#toggleActionsSwitch').is(':checked'));
});
}

// Flag to prevent multiple initializations
var logsTableInitialized = false;

function safeInitLogsTable() {
if (logsTableInitialized) 
return;



logsTableInitialized = true;
setTimeout(function () {
initActivityLogsTable();
}, 0);
}

$(document).ready(safeInitLogsTable);

document.addEventListener('turbo:load', function () {
logsTableInitialized = false;
if (window.jQuery) 
safeInitLogsTable();



});

document.addEventListener('turbo:before-cache', function () {
if ($.fn.DataTable.isDataTable('#activityLogsTable')) {
$('#activityLogsTable').DataTable().destroy();
}
logsTableInitialized = false;
});
})(jQuery);
	</script>
{% endblock %}
