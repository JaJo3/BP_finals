						<i class="bi bi-facebook fs-6 footer-icon"></i>
					</a>
					<a href="#" class="btn btn-sm rounded-circle p-2 d-inline-flex align-items-center justify-content-center border-0 transition-all" style="width: 36px; height: 36px; background-color: #1A3D7C;" title="Twitter" onmouseover="this.style.backgroundColor='#143063';" onmouseout="this.style.backgroundColor='#1A3D7C';">
