{% extends 'base.html.twig' %}

{% block title %}Log in
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		#mainNavbar {
			display: none !important;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="d-flex vh-100 align-items-center justify-content-center w-100" style="background: linear-gradient(160deg, #eef2f7 0%, #e0e7ef 40%, #d4dce8 100%);">
		<div
			class="card border-0 shadow-sm rounded-3" style="max-width: 400px; width: 95%;">
			{# Header: Logo and "Log in" text stacked vertically #}
			<div class="d-flex flex-column align-items-center justify-content-center gap-2 pt-4 pb-3 px-4 border-bottom">
				<img src="{{ asset('images/beatpass-logo.png') }}" alt="BeatPass" class="d-block" style="width: 120px; height: auto;">
				<h1 class="m-0 fw-bold" style="font-size: 1.5rem; color: #1A3D7C;">Log in</h1>
			</div>

			<div class="card-body p-4">
				{% if error is defined and error %}
					<div class="alert alert-danger small mb-3">{{ error }}</div>
				{% endif %}

				<form method="post" action="{{ path('app_login') }}" novalidate>
					<input
					type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

					{# Email input #}
					<div class="mb-3">
						<label for="username" class="form-label small mb-1" style="color: #374151;">Email</label>
						<input id="username" name="username" type="email" value="{{ last_username|default('') }}" class="form-control form-control-sm" required autocomplete="email">
					</div>

					{# Password input #}
					<div class="mb-3">
						<label for="password" class="form-label small mb-1" style="color: #374151;">Password</label>
						<input id="password" name="password" type="password" class="form-control form-control-sm" required autocomplete="current-password">
					</div>

					{# Forgot Password link #}
					<div class="text-end mb-3">
						<a href="#" class="small text-primary text-decoration-none">Forgot Password?</a>
					</div>

					{# Log in button #}
					<div class="d-grid mb-3">
						<button type="submit" class="btn btn-lg fw-semibold" style="background-color: #1A3D7C; color: #fff; border: none;">
							Log in
						</button>
					</div>

					{# Google Sign in #}
					<div class="text-center mb-3">
						<a href="{{ path('connect_google_start') }}" class="text-primary text-decoration-none">
							Sign in with Google
						</a>
					</div>

					{# Sign up prompt #}
					<div class="text-center small mb-3" style="color: #6B7280;">
						Don't have an account?
						<a href="{{ path('app_register') }}" class="text-primary text-decoration-none fw-500">Sign Up</a>
					</div>
				</form>
			</div>
		</div>
	</div>
{% endblock %}
