{% extends 'base.html.twig' %}

{% block title %}Log in
{% endblock %}

{% block stylesheets %}
	{{ parent() }}
	<style>
		/* Hide main navbar on login page - page specific */
		#mainNavbar {
			display: none !important;
		}
	</style>
{% endblock %}

{% block body %}
	<div class="auth-page d-flex vh-100 align-items-start justify-content-center w-100 p-3 p-sm-4 pt-5" style="overflow-y: auto; min-height: 100svh; background: linear-gradient(135deg, #0f172a 0%, #1a1f3a 25%, #2d1b4e 50%, #1a1f3a 75%, #0f172a 100%);">
		<div class="position-relative" style="width: 100%; max-width: 450px;">
			<div
				class="auth-card card shadow-lg rounded-4 border-0 auth-animate w-100 overflow-hidden" style="max-width: 450px; margin-top: 30px; padding-top: 90px; padding-bottom: 30px;">
				{# Logo: Above the card with overlap #}
				<div class="text-center position-absolute start-50 translate-middle-x" style="top: -10px; z-index: 10;">
					<img src="{{ asset('images/beatpass-logo.png') }}" alt="BeatPass" class="d-block mx-auto" style="width: 140px; height: auto;">
				</div>
				<div class="card-body text-center d-flex flex-column align-items-center pb-0 px-3 px-sm-4 pt-0">
					<h1 class="fs-3 fw-bold text-primary mb-0 auth-animate auth-animate-delay-1" style="color: #17366C !important; letter-spacing: -0.5px;">Welcome Back</h1>
					<p class="text-muted small mb-1 auth-animate auth-animate-delay-1" style="font-size: 0.8rem;">Access your tickets now</p>
				</div>

				<div class="card-body p-3 p-sm-4 pt-0">
					<form method="post" action="{{ path('app_login') }}" novalidate autocomplete="off">
						<input
						type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

						{# Email input with icon #}
						<div class="mb-1 auth-animate auth-animate-delay-2">
							<label for="username" class="form-label small fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px; color: #1f2937;">Email</label>
							<div class="input-group">
								<span class="input-group-text bg-light border-end-0" style="border-color: #e5e7eb; border-radius: 10px 0 0 10px;">
									<i class="bi bi-envelope text-muted"></i>
								</span>
								<input id="username" name="username" type="email" class="form-control bg-light border-start-0 ps-0" style="border-color: #e5e7eb; border-radius: 0 10px 10px 0;" placeholder="you@example.com" required autocomplete="off">
							</div>
							{% if error is defined and error and ('user' in error|lower or 'email' in error|lower or 'not found' in error|lower) %}
								<div class="d-flex align-items-center gap-1 mt-1 small" style="font-size: 0.75rem; color: #dc3545;">
									<i class="bi bi-exclamation-circle"></i>
									<span>{{ error }}</span>
								</div>
							{% endif %}
						</div>

						{# Password input with icon and visibility toggle #}
						<div class="mb-1 auth-animate auth-animate-delay-3">
							<label for="password" class="form-label small fw-semibold text-uppercase" style="font-size: 0.75rem; letter-spacing: 0.5px; color: #1f2937;">Password</label>
							<div class="input-group">
								<span class="input-group-text bg-light border-end-0" style="border-color: #e5e7eb; border-radius: 10px 0 0 10px;">
									<i class="bi bi-lock text-muted"></i>
								</span>
								<input id="password" name="password" type="password" class="form-control bg-light border-start-0 border-end-0 ps-0 flex-grow-1" style="border-color: #e5e7eb;" placeholder="Enter your password" required autocomplete="new-password">
								<button type="button" class="input-group-text bg-light border-start-0" id="passwordToggle" tabindex="-1" aria-label="Toggle password visibility" style="border-color: #e5e7eb; border-radius: 0 10px 10px 0; cursor: pointer; flex-shrink: 0;">
									<i class="bi bi-eye text-muted"></i>
								</button>
							</div>
							{% if error is defined and error and ('password' in error|lower or 'invalid' in error|lower or 'cannot be empty' in error|lower) %}
								<div class="d-flex align-items-center gap-1 mt-1 small" style="font-size: 0.75rem; color: #dc3545;">
									<i class="bi bi-exclamation-circle"></i>
									<span>{{ error }}</span>
								</div>
							{% elseif error is defined and error and not ('user' in error|lower or 'email' in error|lower or 'not found' in error|lower) %}
								<div class="d-flex align-items-center gap-1 mt-1 small" style="font-size: 0.75rem; color: #dc3545;">
									<i class="bi bi-exclamation-circle"></i>
									<span>{{ error }}</span>
								</div>
							{% endif %}
						</div>

						{# Forgot Password link #}
						<a href="#" class="text-decoration-none small text-muted text-end d-block mt-1 mb-2 link-primary" style="margin-top: 30px;">Forgot Password?</a>

						{# Log in button #}
						<button type="submit" class="btn w-100 fw-bold py-2 text-uppercase shadow-sm auth-animate auth-animate-delay-4 text-white d-flex align-items-center justify-content-center gap-2 mb-2" style="border-radius: 0.5rem; background: #1a3d7c; border: none; font-size: 0.9rem;">
							<span>LOG IN</span>
							<i class="bi bi-arrow-right"></i>
						</button>

						{# OR Divider #}
						<div class="d-flex align-items-center my-2" style="gap: 1rem;">
							<div class="flex-grow-1" style="height: 1px; background: #e5e7eb;"></div>
							<span class="text-muted small" style="font-size: 0.75rem; color: #6b7280;">OR</span>
							<div class="flex-grow-1" style="height: 1px; background: #e5e7eb;"></div>
						</div>

						{# Google Sign in Button #}
						<a href="{{ path('connect_google_start') }}" class="btn btn-light border w-100 d-flex align-items-center justify-content-center gap-2 fw-semibold auth-animate auth-animate-delay-5" style="border-radius: 10px; border-width: 2px;">
							<svg width="18" height="18" viewbox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg">
								<path fill="#4285F4" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
								<path fill="#34A853" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
								<path fill="#FBBC05" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
								<path fill="#EA4335" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
							</svg>
							Continue with Google
						</a>

						{# Sign up prompt #}
						<div class="text-center text-muted small pt-1" style="margin-top: 1rem;">
							<span style="font-size: 0.75rem;">Don't have an account yet?</span>
							<a href="{{ path('app_register') }}" class="fw-bold link-primary text-decoration-none" style="color: #1a3d7c; font-size: 0.75rem;">Create one now</a>
						</div>
					</form>
				</div>
			</div>
		</div>
	</div>

	<script>
		document.addEventListener('DOMContentLoaded', function () {
const passwordInput = document.getElementById('password');
const passwordToggle = document.getElementById('passwordToggle');
const emailInput = document.getElementById('username');

// Clear inputs on page load/refresh to prevent caching
if (emailInput) 
emailInput.value = '';



if (passwordInput) 
passwordInput.value = '';



// Function to hide error messages
function hideErrorMessages() {
const errorElements = document.querySelectorAll('.alert');
errorElements.forEach(function (element) {
element.style.display = 'none';
});
}

// Hide errors when user starts typing in email field
if (emailInput) {
emailInput.addEventListener('input', function () {
hideErrorMessages();
this.classList.remove('is-invalid');
});
}

// Hide errors when user starts typing in password field
if (passwordInput) {
passwordInput.addEventListener('input', function () {
hideErrorMessages();
this.classList.remove('is-invalid');
});
}

if (passwordToggle && passwordInput) {
passwordToggle.addEventListener('click', function (e) {
e.preventDefault();
const isPassword = passwordInput.type === 'password';
passwordInput.type = isPassword ? 'text' : 'password';

const icon = this.querySelector('i');
if (icon) {
icon.classList.toggle('bi-eye');
icon.classList.toggle('bi-eye-slash');
}
});

if (passwordInput.type === 'text') {
const icon = passwordToggle.querySelector('i');
if (icon) {
icon.classList.remove('bi-eye');
icon.classList.add('bi-eye-slash');
}
}
}
});
	</script>
{% endblock %}
