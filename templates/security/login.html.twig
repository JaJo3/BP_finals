{% extends 'base.html.twig' %}

{% block title %}Log in{% endblock %}

{% block body %}
<div class="d-flex align-items-center justify-content-center min-vh-100 bg-light">
  <div class="card shadow-sm border-0" style="max-width: 400px; width: 100%;">
    <div class="card-body p-4">
      <div class="text-center mb-4">
        <img src="{{ asset('images/beatpass-logo.png') }}" alt="BeatPass" class="img-fluid mb-2" style="max-height: 40px;">
        <h1 class="h5 mb-1 text-beatpass-blue">Log in</h1>
        <p class="text-muted small mb-0">Sign in to continue to your account</p>
      </div>

      {% if error is defined and error %}
        <div class="alert alert-danger small">{{ error }}</div>
      {% endif %}

      <form method="post" action="{{ path('app_login') }}" novalidate>
        <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

        <div class="mb-3">
          <label for="username" class="form-label small mb-1">Email</label>
          <input
            id="username"
            name="username"
            type="email"
            value="{{ last_username|default('') }}"
            class="form-control"
            required
            autocomplete="email">
        </div>

        <div class="mb-3">
          <div class="d-flex justify-content-between align-items-center mb-1">
            <label for="password" class="form-label small mb-0">Password</label>
            <a href="#" class="btn btn-link p-0 small">Forgot password?</a>
          </div>
          <input
            id="password"
            name="password"
            type="password"
            class="form-control"
            required
            autocomplete="current-password">
        </div>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <div class="form-check">
            <input class="form-check-input" type="checkbox" value="1" id="remember_me" name="remember_me">
            <label class="form-check-label small" for="remember_me">Remember me</label>
          </div>
        </div>

        <div class="d-grid mb-3">
          <button type="submit" class="btn btn-primary">
            Log in
          </button>
        </div>

        <div class="text-center small text-muted">
          Don't have an account?
          <a href="{{ path('app_register') }}" class="btn btn-link p-0 align-baseline small">Sign up</a>
        </div>
      </form>
    </div>
  </div>
</div>

{% endblock %}
