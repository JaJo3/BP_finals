{% extends 'base.html.twig' %}

{% block title %}BeatPass | Concert Ticketing
{% endblock %}

{% block body %}

	{# HEADER #}
	{% include 'partials/header.html.twig' %}

	{# HERO — Modern full-screen with gradient overlay and improved hierarchy #}
	{% set featuredEvent = (events is defined and events|length > 0) ? events[0].event : null %}
	<section
		id="home" class="position-relative min-vh-100 d-flex align-items-center justify-content-center overflow-hidden">
		<!-- Background Image -->
		<div class="position-absolute top-0 start-0 w-100 h-100" style="background: url('{{ asset('images/tj-jz.jpg') }}') center/cover no-repeat;" aria-hidden="true"></div>

		<!-- Dark Gradient Overlay -->
		<div class="position-absolute top-0 start-0 w-100 h-100 bg-dark" style="opacity: 0.6; background: linear-gradient(to bottom, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0.7) 100%);" aria-hidden="true"></div>

		<!-- Content -->
		<div class="position-relative container z-3">
			<div class="row justify-content-center">
				<div class="col-lg-8 col-xl-6 text-center">
					<div
						class="fade-up js-reveal" data-delay="0ms">
						<!-- Main Headline -->
						<h1 class="display-3 fw-bold text-white mb-3 lh-sm">
							Your Gateway to
							<span class="text-warning">Live Music!</span>
						</h1>

						<!-- Description -->
						<p class="lead text-light mb-4 mx-auto w-75 opacity-75">
							Discover, book, and experience unforgettable concerts. BeatPass makes it easy to find your next favorite show.
						</p>

						<!-- CTA Buttons -->
						<div class="d-flex flex-wrap justify-content-center gap-3 mb-4">
							<a class="btn btn-warning btn-lg px-4 fw-semibold" href="{{ path('app_events') }}">
								<i class="bi bi-calendar2-event me-2"></i>
								Browse Events
							</a>
							<a class="btn btn-outline-light btn-lg px-4 fw-semibold" href="{{ path('app_register') }}">
								<i class="bi bi-mic me-2"></i>
								Learn More
							</a>
						</div>

						<!-- Trust Indicators -->
						<div class="d-flex flex-wrap justify-content-center gap-4 text-light opacity-75 small">
							<div class="d-flex align-items-center gap-2">
								<i class="bi bi-shield-check text-warning"></i>
								Secure Booking
							</div>
							<div class="d-flex align-items-center gap-2">
								<i class="bi bi-lightning-charge text-warning"></i>
								Instant Tickets
							</div>
							<div class="d-flex align-items-center gap-2">
								<i class="bi bi-bell text-warning"></i>
								Live Updates
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{# EVENTS PREVIEW #}
	<section id="events-preview" class="py-5 bg-white">
		<div
			class="container">
			{# Section Header #}
			<div class="d-flex flex-wrap justify-content-between align-items-center gap-3 mb-4 fade-up js-reveal" data-delay="0ms">
				<div>
					<p class="text-uppercase small fw-semibold text-secondary mb-2">What's On</p>
					<h2 class="fw-bold display-6 mb-0" style="color: #1A3D7C;">Upcoming Shows</h2>
				</div>
				<a class="btn btn-primary rounded-pill px-4 d-inline-flex align-items-center gap-2 transition-all" href="{{ path('app_events') }}" style="background: #1A3D7C; border-color: #1A3D7C; color: white; --bs-btn-hover-bg: #143063; --bs-btn-hover-border-color: #143063; --bs-btn-hover-color: white; --bs-btn-active-bg: #0f2550; --bs-btn-active-border-color: #0f2550; --bs-btn-active-color: white;">
					<span>More events</span>
					<i class="bi bi-arrow-right"></i>
				</a>
			</div>

			{# Events Grid #}
			<div class="row g-4">
				{% if events is defined and events|length > 0 %}
					{% for item in events|slice(0, 6) %}
						{% set event = item.event %}
						<div class="col-md-6 col-lg-4">
							<div
								class="card h-100 border-0 shadow-sm rounded-4 overflow-hidden fade-up js-reveal transition-all hover-shadow-lg" data-delay="{{ (loop.index0 * 100) ~ 'ms' }}">
								{# Card Image #}
								<div class="position-relative" style="height: 200px; overflow: hidden;">
									<img src="{{ asset(event.poster ?: 'images/beatpass.png') }}" class="img-fluid w-100 h-100 object-fit-cover" alt="{{ event.eventName ?: 'Event' }}" loading="lazy">
									<div class="position-absolute top-0 end-0 m-3">
										<span class="badge rounded-pill bg-warning text-dark fw-semibold">
											{{ event.status ?: 'Upcoming' }}
										</span>
									</div>
								</div>

								{# Card Body #}
								<div
									class="card-body p-4 d-flex flex-column">
									{# Event Title #}
									<h5 class="card-title fw-bold fs-5 mb-3" style="color: #1A3D7C;">
										{{ event.eventName ?: 'Untitled event' }}
									</h5>

									{# Event Details #}
									<div class="mb-3">
										<div class="text-muted small d-flex align-items-center gap-2 mb-2">
											<i class="bi bi-calendar3" style="color: #1A3D7C;"></i>
											<span>{{ event.date ? event.date|date('D, d M Y') : 'Date TBA' }}</span>
										</div>
										<div class="text-muted small d-flex align-items-center gap-2">
											<i class="bi bi-geo-alt-fill" style="color: #1A3D7C;"></i>
											<span class="text-truncate">{{ event.venue ?: 'Location TBA' }}</span>
										</div>
									</div>

									{# Price & Button Row #}
									<div class="mt-auto d-flex justify-content-between align-items-center gap-3">
										{% if item.minPrice is not null %}
											<span class="fw-bold fs-5" style="color: #1A3D7C;">
												₱{{ item.minPrice|number_format(0, '.', ',') }}+
											</span>
										{% else %}
											<span class="badge bg-secondary">Price TBA</span>
										{% endif %}
									</div>

									{# Get Tickets Button - Full Width #}
									<a class="btn btn-primary w-100 mt-3 d-inline-flex align-items-center justify-content-center gap-2" href="{{ path('event_show', {'id': event.id}) }}" style="background: #1A3D7C; border-color: #1A3D7C;">
										<i class="bi bi-ticket-perforated"></i>
										<span>Get Tickets</span>
									</a>
								</div>
							</div>
						</div>
					{% endfor %}
				{% else %}
					<div class="col-12">
						<div class="alert alert-light border shadow-sm rounded-4 p-4">
							<div class="d-flex align-items-center gap-3">
								<i class="bi bi-calendar-x fs-1 text-muted"></i>
								<div>
									<h5 class="fw-bold mb-1">No upcoming events yet</h5>
									<p class="text-muted mb-0">Once events are published, they'll appear here automatically.</p>
								</div>
							</div>
						</div>
					</div>
				{% endif %}
			</div>
		</div>
	</section>

	{# UPCOMING EVENTS (CARD GRID) #}
	<section id="upcoming-events" class="py-5 border-top" style="background-color: #1A3D7C;">
		<div class="container">
			<div class="row align-items-end g-4 mb-5 fade-up js-reveal" data-delay="0ms">
				<div class="col-lg-8">
					<p class="text-uppercase small fw-semibold text-white-50 mb-2">Starred Artists</p>
					<h2 class="fw-bold mb-4 fs-2 text-white">Live Performances</h2>
					<div class="border-bottom border-warning border-3 w-25 mb-4"></div>
					<p class="text-white-75 mb-0">Experience world-class performances from your favorite artists.</p>
				</div>
				<div class="col-lg-4 text-lg-end">
					<a class="btn btn-primary btn-pill px-4 py-2 text-white fw-semibold" href="{{ path('app_events') }}" style="background: #1A3D7C; border-color: #1A3D7C; --bs-btn-hover-bg: #143063; --bs-btn-hover-border-color: #143063; --bs-btn-hover-color: white; --bs-btn-active-bg: #0f2550; --bs-btn-active-border-color: #0f2550; --bs-btn-active-color: white;">
						<span>More events</span>
						<i class="bi bi-arrow-right-circle-fill ms-2"></i>
					</a>
				</div>
			</div>

			{% if events is defined and events|length > 0 %}
				<div class="row g-4">
					{% for item in events|slice(0, 8) %}
						{% set event = item.event %}
						<div class="col-sm-6 col-lg-3 fade-up js-reveal" data-delay="{{ (loop.index0 * 70) ~ 'ms' }}">
							<div class="event-card-grid position-relative overflow-hidden rounded-4 h-100 transition-card shadow-sm border border-light" style="min-height: 300px;">
								<a href="{{ path('event_show', {'id': event.id}) }}" class="stretched-link z-3" aria-label="View {{ event.eventName ?: 'Event' }}"></a>

								<!-- Event Poster Background -->
								<img
								src="{{ asset(event.poster ?: 'images/beatpass.png') }}" alt="{{ event.eventName ?: 'Event' }}" class="w-100 h-100 object-fit-cover" loading="lazy" style="position: absolute; inset: 0;">

								<!-- Subtle Overlay Gradient -->
								<div class="position-absolute bottom-0 start-0 end-0" style="height: 140px; background: linear-gradient(to top, rgba(26, 61, 124, 0.85), rgba(26, 61, 124, 0.2));"></div>

								<!-- Artist Name & Arrow -->
								<div class="position-absolute bottom-0 start-0 end-0 p-4 d-flex align-items-end justify-content-between z-2">
									<div class="flex-grow-1">
										<h5 class="fw-bold text-white mb-0 fs-6">{{ event.organizer ? event.organizer.orgName : 'Artist' }}</h5>
										<p class="text-white-50 small mb-0" style="font-size: 0.75rem;">{{ event.eventName }}</p>
									</div>
									<a href="{{ path('event_show', {'id': event.id}) }}" class="ms-3 flex-shrink-0 text-warning text-decoration-none d-inline-flex align-items-center justify-content-center transition-all">
										<i class="bi bi-arrow-right fs-5 transition-all"></i>
									</a>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			{% else %}
				<div class="alert alert-info border mb-0">
					<div class="fw-semibold">No upcoming events yet</div>
					<div class="text-muted small">Publish an event to appear here automatically.</div>
				</div>
			{% endif %}
		</div>

	</section>

	{# HOW IT WORKS #}
	<section id="how-it-works" class="py-5 bg-white">
		<div class="container">
			<div class="row align-items-end g-4 mb-4 fade-up js-reveal" data-delay="0ms">
				<div class="col-lg-8">
					<p class="text-uppercase small fw-semibold text-secondary mb-2">Simple flow</p>
					<h2 class="fw-bold mb-4 fs-2" style="color: #1A3D7C;">How it works</h2>
					<div class="border-bottom border-warning border-3 w-25 mb-4"></div>
					<p class="text-muted mb-0">A smooth ticketing journey built for mobile-first conversion.</p>
				</div>
				<div class="col-lg-4 text-lg-end">
					<div class="d-inline-flex align-items-center gap-2 text-secondary small mb-0 px-3 py-2 rounded-pill bg-white border">
						<i class="bi bi-lightning-charge text-warning"></i>
						Fast steps, instant confirmation
					</div>
				</div>
			</div>

			<div class="row g-4">
				<div class="col-md-6 col-lg-3 d-flex">
					<div class="p-4 bg-white rounded-4 shadow-soft lift h-100 w-100 fade-up js-reveal border border-light" data-delay="0ms">
						<div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px; background: rgba(26, 61, 124, 0.1);">
							<i class="bi bi-calendar2-event fs-2" style="color: #1A3D7C;"></i>
						</div>
						<h5 class="fw-semibold mb-2">Browse Events</h5>
						<p class="text-body-secondary mb-0 small">Discover what's next with curated shows and verified organizers.</p>
					</div>
				</div>

				<div class="col-md-6 col-lg-3 d-flex">
					<div class="p-4 bg-white rounded-4 shadow-soft lift h-100 w-100 fade-up js-reveal border border-light" data-delay="70ms">
						<div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px; background: rgba(249, 178, 51, 0.15);">
							<i class="bi bi-ticket-perforated fs-2" style="color: #f9b233;"></i>
						</div>
						<h5 class="fw-semibold mb-2">Choose Ticket</h5>
						<p class="text-body-secondary mb-0 small">Pick your tier and review the details before you pay.</p>
					</div>
				</div>

				<div class="col-md-6 col-lg-3 d-flex">
					<div class="p-4 bg-white rounded-4 shadow-soft lift h-100 w-100 fade-up js-reveal border border-light" data-delay="140ms">
						<div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px; background: rgba(25, 135, 84, 0.1);">
							<i class="bi bi-credit-card-2-front fs-2 text-success"></i>
						</div>
						<h5 class="fw-semibold mb-2">Secure Payment</h5>
						<p class="text-body-secondary mb-0 small">Checkout securely with clear totals and trusted flows.</p>
					</div>
				</div>

				<div class="col-md-6 col-lg-3 d-flex">
					<div class="p-4 bg-white rounded-4 shadow-soft lift h-100 w-100 fade-up js-reveal border border-light" data-delay="210ms">
						<div class="rounded-3 d-inline-flex align-items-center justify-content-center mb-3" style="width:56px;height:56px; background: rgba(26, 61, 124, 0.1);">
							<i class="bi bi-check-circle-fill fs-2" style="color: #1A3D7C;"></i>
						</div>
						<h5 class="fw-semibold mb-2">Get Confirmation</h5>
						<p class="text-body-secondary mb-0 small">Instant confirmation so you can focus on the show.</p>
					</div>
				</div>
			</div>
		</div>
	</section>

	{# SEATING AND PRICING #}
	<section id="pricing" class="pricing-section py-5 border-top border-bottom" style="background-color: #1A3D7C;">
		<div
			class="container">
			{# Pricing Header #}
			<div class="text-center mb-5 fade-up js-reveal" data-delay="0ms">
				<p class="text-uppercase small fw-semibold text-white-50 mb-2">Find Your Seating</p>
				<h2 class="display-5 fw-bold mb-4 text-white">Choose Your Perfect Ticket Tier</h2>
				<div class="border-bottom border-warning border-3 w-25 mx-auto mb-4"></div>
				<p class="lead text-white-75">Select the experience that fits your concert preferences</p>
			</div>

			{# Pricing Cards #}
			<div class="row g-4 justify-content-center">
				{% if ticketTiers is defined and ticketTiers|length > 0 %}
					{% for index, tier in ticketTiers %}
						{% set isMiddle = (ticketTiers|length == 3 and index == 1) or (ticketTiers|length == 2 and index == 1) or (ticketTiers|length > 3 and index == ticketTiers|length // 2) %}
						{% set tierName = tier.type %}
						{% set tierPrice = tier.minPrice %}
						{% set maxPrice = tier.maxPrice %}
						{% set isAvailable = tier.avgQuantity > 0 %}

						<div class="col-12 col-md-6 col-lg-3 fade-up js-reveal" data-delay="{{ (index * 70) ~ 'ms' }}">
							<div class="pricing-card {% if isMiddle %}pricing-card-featured{% endif %} rounded-4 shadow-{% if isMiddle %}lg{% else %}sm{% endif %} p-4 h-100 {% if isMiddle %}{% else %}border border-light{% endif %} d-flex flex-column{% if isMiddle %} position-relative{% endif %}" {% if isMiddle %} style="transform: scale(1.05); background: linear-gradient(135deg, #1a3d7c 0%, #0d2448 100%);" {% else %} style="background: #ffffff;" {% endif %}>
								{% if isMiddle %}
									<div class="pricing-badge position-absolute top-0 start-50 translate-middle-x">
										<span class="badge bg-warning text-dark fw-bold">Most Popular</span>
									</div>
								{% endif %}

								<div class="pricing-header mb-4{% if isMiddle %} mt-3{% endif %}">
									<div class="pricing-icon mb-3">
										<i class="bi bi-ticket-perforated fs-3{% if isMiddle %} text-white{% else %}" style="color: #1A3D7C;{% endif %}"></i>
									</div>
									<h3 class="h5 fw-bold {% if isMiddle %}text-white{% else %}text-dark{% endif %}">{{ tierName }}</h3>
								</div>

								<div class="pricing-amount mb-3">
									<span class="fs-2 fw-bold {% if isMiddle %}text-white{% else %}text-dark{% endif %}">₱{{ tierPrice|number_format(0, '.', ',') }}</span>
									<span class="{% if isMiddle %}text-white-50{% else %}text-muted{% endif %} small">
										{% if tierPrice != maxPrice %}
											to ₱{{ maxPrice|number_format(0, '.', ',') }}
										{% else %}
											fixed price
										{% endif %}
									</span>
								</div>

								<ul class="pricing-features list-unstyled mb-4 flex-grow-1">
									<li class="mb-2 d-flex align-items-center gap-2">
										<i class="bi bi-check-circle-fill {% if isMiddle %}text-white{% else %}" style="color: #1A3D7C;{% endif %} flex-shrink-0"></i>
										<span class="{% if isMiddle %}text-white{% else %}text-dark{% endif %} small">{{ tierName }}
											Seating</span>
									</li>
									<li class="mb-2 d-flex align-items-center gap-2">
										<i class="bi bi-check-circle-fill {% if isMiddle %}text-white{% else %}" style="color: #1A3D7C;{% endif %} flex-shrink-0"></i>
										<span class="{% if isMiddle %}text-white{% else %}text-dark{% endif %} small">Priority Entry</span>
									</li>
									<li class="mb-2 d-flex align-items-center gap-2">
										<i class="bi bi-check-circle-fill {% if isMiddle %}text-white{% else %}" style="color: #1A3D7C;{% endif %} flex-shrink-0"></i>
										<span class="{% if isMiddle %}text-white{% else %}text-dark{% endif %} small">Event Access</span>
									</li>
									<li class="mb-2 d-flex align-items-center gap-2">
										<i class="bi bi-check-circle-fill {% if isMiddle %}text-white{% else %}" style="color: #1A3D7C;{% endif %} flex-shrink-0"></i>
										<span class="{% if isMiddle %}text-white{% else %}text-dark{% endif %} small">QR Code Ticket</span>
									</li>
									{% if isMiddle %}
										<li class="mb-2 d-flex align-items-center gap-2">
											<i class="bi bi-check-circle-fill text-white flex-shrink-0"></i>
											<span class="text-white small">Exclusive Benefits</span>
										</li>
									{% endif %}
								</ul>

								<button class="btn btn-warning rounded-pill w-100 py-2 fw-semibold {% if isMiddle %}text-dark{% else %}text-dark{% endif %}">
									Get Ticket
								</button>
							</div>
						</div>
					{% endfor %}
				{% else %}
					{# Fallback to static tiers if no database tiers found #}
					{# Regular Tier #}
						<div class="col-12 col-md-6 col-lg-3 fade-up js-reveal" data-delay="0ms"> <div class="pricing-card rounded-4 shadow-sm p-4 h-100 border border-light d-flex flex-column" style="background: #ffffff;">
							<div class="pricing-header mb-4">
								<div class="pricing-icon mb-3">
									<i class="bi bi-music-note-beamed fs-3" style="color: #1A3D7C;"></i>
								</div>
								<h3 class="h5 fw-bold text-dark">General Admission</h3>
							</div>

							<div class="pricing-amount mb-3">
								<span class="fs-2 fw-bold text-dark">₱500</span>
								<span class="text-muted small">typical price</span>
							</div>

							<ul class="pricing-features list-unstyled mb-4 flex-grow-1">
								<li class="mb-2 d-flex align-items-center gap-2">
									<i class="bi bi-check-circle-fill flex-shrink-0" style="color: #1A3D7C;"></i>
									<span class="text-dark small">GA Seating</span>
								</li>
								<li class="mb-2 d-flex align-items-center gap-2">
									<i class="bi bi-check-circle-fill flex-shrink-0" style="color: #1A3D7C;"></i>
									<span class="text-dark small">Event Access</span>
								</li>
								<li class="mb-2 d-flex align-items-center gap-2">
									<i class="bi bi-check-circle-fill flex-shrink-0" style="color: #1A3D7C;"></i>
									<span class="text-dark small">QR Code Ticket</span>
								</li>
								<li class="mb-2 d-flex align-items-center gap-2">
									<i class="bi bi-circle text-muted flex-shrink-0" style="opacity: 0.5;"></i>
									<span class="text-muted small" style="opacity: 0.6;">VIP Perks</span>
								</li>
							</ul>

							<button class="btn btn-warning rounded-pill w-100 py-2 fw-semibold text-dark">
								Get Ticket
							</button>
						</div>
					</div>

					{# VIP Tier (Featured) #}
					<div class="col-12 col-md-6 col-lg-3 fade-up js-reveal" data-delay="70ms">
						<div class="pricing-card pricing-card-featured rounded-4 shadow-lg p-4 h-100 d-flex flex-column position-relative" style="transform: scale(1.05); background: linear-gradient(135deg, #1a3d7c 0%, #0d2448 100%);">
							<div class="pricing-badge position-absolute top-0 start-50 translate-middle-x">
								<span class="badge bg-warning text-dark fw-bold">Most Popular</span>
							</div>

							<div class="pricing-header mb-4 mt-3">
								<div class="pricing-icon mb-3">
									<i class="bi bi-ticket-perforated fs-3 text-white"></i>
								</div>
								<h3 class="h5 fw-bold text-white">VIP</h3>
							</div>

							<div class="pricing-amount mb-3">
								<span class="fs-2 fw-bold text-white">₱1,200</span>
								<span class="text-white-50 small">premium experience</span>
							</div>

							<ul class="pricing-features list-unstyled mb-4 flex-grow-1">
								<li class="mb-2 d-flex align-items-center gap-2">
									<i class="bi bi-check-circle-fill text-white flex-shrink-0"></i>
									<span class="text-white small">VIP Seating</span>
								</li>
								<li class="mb-2 d-flex align-items-center gap-2">
									<i class="bi bi-check-circle-fill text-white flex-shrink-0"></i>
									<span class="text-white small">Premium Location</span>
								</li>
								<li class="mb-2 d-flex align-items-center gap-2">
									<i class="bi bi-check-circle-fill text-white flex-shrink-0"></i>
									<span class="text-white small">Event Access</span>
								</li>
