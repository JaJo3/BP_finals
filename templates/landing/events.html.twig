{% extends 'base.html.twig' %}

{% block title %}All Events - BeatPass
{% endblock %}

{% block body_class %}bg-white
{% endblock %}

{% block body_outer %}
	{# EVENTS PAGE HERO SECTION #}
	<section class="py-5 py-lg-5 bg-brand-gradient text-white position-relative overflow-hidden">
		<div class="container">
			<div class="row align-items-center g-4">
				<div class="col-lg-8">
					<div class="fade-up js-reveal" data-delay="0ms">
						<span class="badge rounded-pill text-bg-light text-brand px-3 py-2 mb-3 shadow-soft">
							<i class="bi bi-calendar2-event me-1"></i>Browse all events
						</span>
						<h1 class="display-4 fw-bold lh-sm mb-3">
							Discover upcoming concerts & events
						</h1>
						<p class="lead text-white-50 mb-4">
							Find the perfect show, book your tickets, and get ready for an unforgettable experience.
														Browse our complete calendar of verified events from trusted organizers.
						</p>
						<div class="d-flex flex-wrap gap-2">
							<a class="btn btn-accent btn-lg btn-pill btn-cta px-4" href="#events-grid">
								<i class="bi bi-search me-2"></i>
								View Events
							</a>
							<a class="btn btn-outline-light btn-outline-brand btn-lg btn-pill btn-cta px-4" href="{{ path('app_landing') }}">
								<i class="bi bi-arrow-left me-2"></i>
								Back to Home
							</a>
						</div>
					</div>
				</div>
				<div class="col-lg-4">
					<div class="fade-up js-reveal" data-delay="90ms">
						<div class="card border-0 shadow-soft rounded-4 bg-white bg-opacity-10 backdrop-blur p-3 p-md-4 text-white border-white border-opacity-10">
							<div class="card-body">
								<div class="display-6 fw-bold mb-2">
									{{ events|length }}
								</div>
								<div class="text-white-50">
									<i class="bi bi-calendar-check me-2"></i>Upcoming events
								</div>
								<hr class="border-white border-opacity-25 my-3">
								<div class="small text-white-50">
									<i class="bi bi-lightning-charge me-2"></i>Updated regularly
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{# SEARCH & FILTER SECTION #}
	<section class="py-4 border-bottom bg-body-tertiary">
		<div class="container">
			<div class="row g-3">
				<div class="col-md-6">
					<label class="form-label fw-semibold small text-muted">Search</label>
					<div class="input-group">
						<span class="input-group-text bg-white">
							<i class="bi bi-search"></i>
						</span>
						<input type="text" class="form-control" id="searchInput" placeholder="Artist name, venue, keyword...">
					</div>
				</div>
				<div class="col-md-6">
					<label class="form-label fw-semibold small text-muted">Sort by</label>
					<select class="form-select" id="sortSelect">
						<option value="date-asc" selected>Upcoming (Earliest first)</option>
						<option value="date-desc">Latest events</option>
						<option value="price-asc">Price: Low to High</option>
						<option value="price-desc">Price: High to Low</option>
						<option value="name-asc">Event name (A-Z)</option>
					</select>
				</div>
			</div>
		</div>
	</section>

	{# EVENTS GRID #}
	<section id="events-grid" class="py-5 py-lg-5">
		<div class="container">
			{% if events is defined and events|length > 0 %}
				<div class="mb-4">
					<p class="text-secondary">
						<i class="bi bi-info-circle me-2"></i>
						Showing
						<strong>{{ events|length }}</strong>
						events
					</p>
				</div>

				<div class="row g-3 g-lg-4" id="eventsContainer">
					{% for item in events %}
						{% set event = item.event %}
						<div class="col-sm-6 col-lg-4 event-card" data-event-name="{{ event.eventName|lower }}" data-event-date="{{ event.date ? event.date|date('U') : 'z' }}" data-event-price="{{ item.minPrice ?? 999999 }}">
							<div
								class="card border-0 shadow-soft lift h-100 fade-up js-reveal" data-delay="{{ (loop.index0 * 70) ~ 'ms' }}" style="border-radius: .95rem;">
								{# Card Header with Event Image #}
								<div class="card-media position-relative overflow-hidden">
									<img
									src="{{ asset(event.poster ?: 'images/beatpass.png') }}" class="w-100" alt="{{ event.eventName ?: 'Event' }}" loading="lazy" style="aspect-ratio: 16/10; object-fit: cover;">
									{# Event Status Badge #}
									<div class="position-absolute top-0 end-0 p-3">
										<span class="badge rounded-pill text-bg-warning-subtle text-warning-emphasis border border-warning-subtle">
											<i class="bi bi-circle-fill me-1" style="font-size: .5rem;"></i>
											{{ event.status ?: 'Upcoming' }}
										</span>
									</div>
								</div>

								{# Card Content #}
								<div
									class="card-body p-4 d-flex flex-column">
									{# Event Title & Status #}
									<div class="d-flex align-items-start justify-content-between gap-3 mb-3">
										<h5 class="card-title fw-semibold mb-0 flex-grow-1">
											{{ event.eventName ?: 'Untitled event' }}
										</h5>
									</div>

									{# Event Details #}
									<div class="text-secondary small d-flex flex-column gap-2 mb-3">
										<span class="d-inline-flex align-items-center gap-2">
											<i class="bi bi-calendar-event" style="min-width: 16px;"></i>
											<span>{{ event.date ? event.date|date('D, d M Y') : 'Date TBA' }}</span>
										</span>
										<span class="d-inline-flex align-items-center gap-2">
											<i class="bi bi-clock" style="min-width: 16px;"></i>
											<span>{{ event.date ? event.date|date('H:i') : 'Time TBA' }}</span>
										</span>
										<span class="d-inline-flex align-items-center gap-2">
											<i class="bi bi-geo-alt" style="min-width: 16px;"></i>
											<span>{{ event.venue ?: 'Location TBA' }}</span>
										</span>
									</div>

									{# Organizer #}
									<div class="text-secondary small mb-3 d-inline-flex align-items-center gap-2">
										<i class="bi bi-building"></i>
										<span>{{ event.organizer ? event.organizer.orgName : 'Organizer TBA' }}</span>
									</div>

									{# Price & CTA Button #}
									<div class="mt-auto pt-2 d-flex align-items-center justify-content-between">
										<div>
											<div class="text-muted small">Starting from</div>
											<div class="fw-semibold text-brand h6 mb-0">
												{% if item.minPrice is not null %}
													€{{ item.minPrice|number_format(2, '.', ',') }}
												{% else %}
													<span class="text-secondary">Price TBA</span>
												{% endif %}
											</div>
										</div>
										<a class="btn btn-sm btn-accent btn-pill btn-cta px-3" href="{{ path('event_show', {'id': event.id}) }}" title="Buy tickets for {{ event.eventName }}">
											<i class="bi bi-ticket-perforated me-1"></i>Tickets
										</a>
									</div>
								</div>
							</div>
						</div>
					{% endfor %}
				</div>
			{% else %}
				{# Empty State #}
				<div class="row">
					<div class="col-12">
						<div class="py-5 text-center">
							<div class="display-1 text-muted mb-3">
								<i class="bi bi-calendar-x"></i>
							</div>
							<h3 class="fw-bold mb-2">No events found</h3>
							<p class="text-secondary mb-4">
								We don't have any upcoming events at the moment. Check back soon!
							</p>
							<a class="btn btn-brand btn-lg btn-pill btn-cta px-4" href="{{ path('app_landing') }}">
								<i class="bi bi-arrow-left me-2"></i>Back to home
							</a>
						</div>
					</div>
				</div>
			{% endif %}
		</div>
	</section>

	{# CTA SECTION #}
	<section class="py-5 py-lg-5 bg-brand-gradient text-white border-top">
		<div class="container">
			<div class="row align-items-center g-4">
				<div class="col-lg-7">
					<div class="fade-up js-reveal" data-delay="0ms">
						<h2 class="fw-bold mb-3">Didn't find what you're looking for?</h2>
						<p class="lead text-white-50 mb-0">
							Create your own event and share it with the community. Sell tickets, manage registrations, 
														and connect with your audience all in one place.
						</p>
					</div>
				</div>
				<div class="col-lg-5 text-lg-end">
					<div class="fade-up js-reveal" data-delay="70ms">
						<div class="d-flex flex-column flex-lg-row gap-3 justify-content-lg-end">
							<a class="btn btn-accent btn-lg btn-pill btn-cta px-4" href="{{ path('app_register') }}">
								<i class="bi bi-person-plus me-2"></i>Create account
							</a>
							<a class="btn btn-outline-light btn-outline-brand btn-lg btn-pill btn-cta px-4" href="{{ path('app_landing') }}#contact">
								<i class="bi bi-chat-left-text me-2"></i>Contact us
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>
{% endblock %}
