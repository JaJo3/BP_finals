{% extends 'base.html.twig' %}

{% block title %}All Events - BeatPass
{% endblock %}

{% block body %}

	{# HEADER #}
	{% include 'partials/header.html.twig' %}

	{# EVENTS PAGE HERO SECTION - Modern Design #}
	<section class="py-5 py-lg-5 text-white position-relative overflow-hidden" style="background: linear-gradient(135deg, #1A3D7C 0%, #0f2550 100%);">
		<div class="container">
			<div class="row justify-content-center text-center">
				<div class="col-lg-8">
					<div
						class="fade-up js-reveal" data-delay="0ms">
						<!-- Badge -->
						<span class="badge rounded-pill px-3 py-2 mb-3 shadow-sm" style="background: rgba(255,255,255,0.2); color: #ffffff; border: 1px solid rgba(255,255,255,0.3);">
							<i class="bi bi-calendar2-event me-1 text-warning"></i>Discover Amazing Events
						</span>

						<!-- Headline -->
						<h1 class="display-4 fw-bold lh-sm mb-3">
							<span class="text-white">Find Your Next</span><br>
							<span class="text-warning">Unforgettable Experience</span>
						</h1>

						<!-- Subtitle -->
						<p class="lead mb-4 mx-auto" style="color: rgba(255,255,255,0.8); max-width: 600px;">
							Browse concerts, festivals, and live shows. Book tickets instantly with secure payments.
						</p>

						<!-- Search Bar -->
						<div class="bg-white rounded-4 p-2 mb-3 shadow-lg mx-auto" style="max-width: 500px;">
							<div class="input-group">
								<span class="input-group-text bg-white border-0">
									<i class="bi bi-search text-muted"></i>
								</span>
								<input type="text" class="form-control border-0 bg-white" id="heroSearchInput" placeholder="Search events, artists, venues...">
								<button class="btn btn-warning rounded-3 px-4 fw-semibold" type="button" onclick="document.getElementById('searchInput').value = document.getElementById('heroSearchInput').value; filterEvents();">
									Search
									<i class="bi bi-arrow-right ms-1"></i>
								</button>
							</div>
						</div>

						<!-- Filter Buttons -->
						<div class="d-flex flex-wrap justify-content-center gap-2 mb-5">
							<button class="btn btn-light rounded-pill px-4 fw-semibold active" data-filter="all">
								All Events
							</button>
							<button class="btn rounded-pill px-4 fw-semibold" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3);" data-filter="upcoming">
								<i class="bi bi-calendar3 me-1"></i>Upcoming
							</button>
							<button class="btn rounded-pill px-4 fw-semibold" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3);" data-filter="popular">
								<i class="bi bi-fire me-1"></i>Popular
							</button>
							<button class="btn rounded-pill px-4 fw-semibold" style="background: rgba(255,255,255,0.2); color: white; border: 1px solid rgba(255,255,255,0.3);" data-filter="this-month">
								<i class="bi bi-calendar-check me-1"></i>This Month
							</button>
						</div>

						<!-- Stats -->
						<div class="d-flex flex-wrap justify-content-center gap-4 gap-md-5">
							<div class="text-center">
								<div class="display-5 fw-bold text-white">{{ events|length }}</div>
								<div class="small" style="color: rgba(255,255,255,0.7);">Events</div>
							</div>
							<div class="text-center">
								<div class="display-5 fw-bold text-white">50+</div>
								<div class="small" style="color: rgba(255,255,255,0.7);">Artists</div>
							</div>
							<div class="text-center">
								<div class="display-5 fw-bold text-white">10K+</div>
								<div class="small" style="color: rgba(255,255,255,0.7);">Tickets Sold</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{# EVENTS GRID #}
	<section id="events-grid" class="py-5 py-lg-5">
		<div class="container" style="max-width: 900px;">
			{% if events is defined and events|length > 0 %}
				{% set grouped_events = {} %}
				{% for item in events %}
					{% set event = item.event %}
					{% if event.date %}
						{% set month_key = event.date|date('F Y') %}
						{% if grouped_events[month_key] is not defined %}
							{% set grouped_events = grouped_events|merge({(month_key): []}) %}
						{% endif %}
						{% set grouped_events = grouped_events|merge({(month_key): grouped_events[month_key]|merge([item])}) %}
					{% endif %}
				{% endfor %}

				{% for month, month_events in grouped_events %}
					{# Month Heading #}
					<h2 class="fw-bold mb-4" style="color: #1f2937; font-size: 1.5rem;">{{ month }}</h2>

					<div class="mb-5">
						{% for item in month_events %}
							{% set event = item.event %}
							<div class="event-card mb-3" data-event-name="{{ event.eventName|lower }}" data-event-date="{{ event.date ? event.date|date('U') : 'z' }}" data-event-price="{{ item.minPrice ?? 999999 }}">
								<div class="card border-0 shadow-sm lift fade-up js-reveal" data-delay="{{ (loop.index0 * 70) ~ 'ms' }}" style="border-radius: .75rem;">
									<div class="card-body p-3">
										<div
											class="row align-items-center g-3">
											{# Date Column #}
											<div class="col-auto text-center" style="min-width: 70px;">
												<div class="text-uppercase small fw-semibold" style="color: #dc2626; font-size: 0.75rem; letter-spacing: 0.5px;">
													{{ event.date ? event.date|date('D') : 'TBA' }}
												</div>
												<div class="fw-bold" style="font-size: 2rem; line-height: 1; color: #1f2937;">
													{{ event.date ? event.date|date('d') : '--' }}
												</div>
												<div class="text-uppercase small" style="color: #6b7280; font-size: 0.75rem;">
													{{ event.date ? event.date|date('M') : '' }}
												</div>
											</div>

											{# Image Column #}
											<div class="col-auto">
												<img src="{{ asset(event.poster ?: 'images/beatpass.png') }}" alt="{{ event.eventName ?: 'Event' }}" loading="lazy" style="width: 100px; height: 70px; object-fit: cover; border-radius: 0.5rem;">
											</div>

											{# Info Column #}
											<div class="col flex-grow-1">
												<h5 class="fw-bold mb-1" style="font-size: 1.1rem; color: #1f2937;">
													{{ event.eventName ?: 'Untitled event' }}
												</h5>
												<div class="text-secondary small mb-1">
													{{ event.organizer ? event.organizer.orgName : 'Organizer TBA' }}
												</div>
												<div class="text-secondary small">
													<i class="bi bi-geo-alt me-1"></i>
													{{ event.venue ?: 'Location TBA' }}
												</div>
											</div>

											{# Button Column #}
											<div class="col-auto">
												<a class="btn fw-semibold px-4" href="{{ path('event_show', {'id': event.id}) }}" style="background: #1a3d7c; color: white; border-radius: 0.375rem; font-size: 0.85rem; border: none;" title="Buy tickets for {{ event.eventName }}">
													Find Tickets
												</a>
											</div>
										</div>
									</div>
								</div>
							</div>
						{% endfor %}
					</div>
				{% endfor %}

				{# Pagination #}
				{% if totalPages > 1 %}
					<nav aria-label="Page navigation" class="mt-4">
						<ul
							class="pagination justify-content-center">
							{# Previous button #}
							<li class="page-item {{ currentPage == 1 ? 'disabled' : '' }}">
								<a class="page-link" href="{{ path('app_events', {'page': currentPage - 1}) }}" style="color: #1a3d7c; border-color: #e5e7eb;">
									<i class="bi bi-chevron-left"></i>
								</a>
							</li>

							{# Page numbers #}
							{% for page in 1..totalPages %}
								{% if page == currentPage %}
									<li class="page-item active">
										<span class="page-link" style="background: #1a3d7c; border-color: #1a3d7c;">{{ page }}</span>
									</li>
								{% elseif page >= currentPage - 2 and page <= currentPage + 2 %}
									<li class="page-item">
										<a class="page-link" href="{{ path('app_events', {'page': page}) }}" style="color: #1a3d7c; border-color: #e5e7eb;">{{ page }}</a>
									</li>
								{% elseif page == 1 or page == totalPages %}
									<li class="page-item">
										<a class="page-link" href="{{ path('app_events', {'page': page }) }}" style="color: #1a3d7c; border-color: #e5e7eb;">{{ page }}</a>
									</li>
								{% elseif page == currentPage - 3 or page == currentPage + 3 %}
									<li class="page-item disabled">
										<span class="page-link" style="border-color: #e5e7eb;">...</span>
									</li>
								{% endif %}
							{% endfor %}

							{# Next button #}
							<li class="page-item {{ currentPage == totalPages ? 'disabled' : '' }}">
								<a class="page-link" href="{{ path('app_events', {'page': currentPage + 1}) }}" style="color: #1a3d7c; border-color: #e5e7eb;">
									<i class="bi bi-chevron-right"></i>
								</a>
							</li>
						</ul>
					</nav>
				{% endif %}
			{% else %}
				{# Empty State #}
				<div class="row">
					<div class="col-12">
						<div class="py-5 text-center">
							<div class="display-1 text-muted mb-3">
								<i class="bi bi-calendar-x"></i>
							</div>
							<h3 class="fw-bold mb-2">No events found</h3>
							<p class="text-secondary mb-4">
								We don't have any upcoming events at the moment. Check back soon!
							</p>
							<a class="btn btn-brand btn-lg btn-pill btn-cta px-4" href="{{ path('app_landing') }}">
								<i class="bi bi-arrow-left me-2"></i>Back to home
							</a>
						</div>
					</div>
				</div>
			{% endif %}
		</div>
	</section>

	{# CTA SECTION #}
	<section class="py-5 py-lg-5 bg-brand-gradient text-white border-top">
		<div class="container">
			<div class="row align-items-center g-4">
				<div class="col-lg-7">
					<div class="fade-up js-reveal" data-delay="0ms">
						<h2 class="fw-bold mb-3">Didn't find what you're looking for?</h2>
						<p class="lead text-white-50 mb-0">
							Create your own event and share it with the community. Sell tickets, manage registrations, 
																																																																						and connect with your audience all in one place.
						</p>
					</div>
				</div>
				<div class="col-lg-5 text-lg-end">
					<div class="fade-up js-reveal" data-delay="70ms">
						<div class="d-flex flex-column flex-lg-row gap-3 justify-content-lg-end">
							<a class="btn btn-accent btn-lg btn-pill btn-cta px-4" href="{{ path('app_register') }}">
								<i class="bi bi-person-plus me-2"></i>Create account
							</a>
							<a class="btn btn-outline-light btn-outline-brand btn-lg btn-pill btn-cta px-4" href="{{ path('app_landing') }}#contact">
								<i class="bi bi-chat-left-text me-2"></i>Contact us
							</a>
						</div>
					</div>
				</div>
			</div>
		</div>
	</section>

	{# FOOTER #}
	{% include 'partials/footer.html.twig' %}
{% endblock %}
