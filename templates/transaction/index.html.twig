{% extends 'admin/base.html.twig' %}

{% block title %}Transactions Management
{% endblock %}

{% block body %}
	<div class="content-wrapper content-wrapper--transactions pt-0">
		<div class="d-flex justify-content-between align-items-center mb-2">
			<h1 class="h5 mb-0" style="color: #1A3D7C;">
				<i class="fas fa-exchange-alt me-2 text-warning"></i>Transactions
			</h1>
			<a href="{{ path('transaction_new') }}" class="btn btn-sm btn-primary" style="background-color: #1A3D7C; border-color: #1A3D7C;">
				<i class="fas fa-plus-circle me-2"></i>Create Transaction
			</a>
		</div>

		<div class="card shadow-sm">
			<div class="card-header d-flex align-items-center justify-content-between py-2" style="background: linear-gradient(135deg, #1A3D7C 0%, #15305A 100%); color: white; border: none;">
				<div class="d-flex align-items-center">
					<h3 class="card-title mb-0" style="font-weight: 600; font-size: 1rem;">
						<i class="fas fa-list me-2" style="color: #F9B233;"></i>All Transactions
					</h3>
				</div>
				<span class="badge bg-warning text-dark fw-bold">{{ transactions|default([])|length }}
					items</span>
			</div>
			<div class="px-3 py-2 d-flex flex-wrap align-items-center gap-2 bg-light border-bottom">
				<div class="form-check form-switch m-0 d-flex align-items-center gap-2 ms-auto">
					<input class="form-check-input m-0" type="checkbox" id="toggleTransactionsActions" role="switch" aria-label="Show actions column">
					<label class="form-check-label small text-muted" for="toggleTransactionsActions" style="user-select:none;">Show actions</label>
				</div>
			</div>
			<div class="card-body p-0">
				<div class="table-responsive">
					<table id="transactionTable" class="table table-sm table-hover beatpass-table mb-0">
						<thead class="table-light">
							<tr>
								<th class="col-id text-nowrap small fw-semibold text-uppercase py-1 px-2">ID</th>
								<th class="col-buyer text-nowrap small fw-semibold text-uppercase py-1 px-2">Buyer</th>
								<th class="col-event text-nowrap small fw-semibold text-uppercase py-1 px-2">Event</th>
								<th class="col-amount text-end text-nowrap small fw-semibold text-uppercase py-1 px-2">Amount</th>
								<th class="col-status text-nowrap small fw-semibold text-uppercase py-1 px-2">Status</th>
								<th class="col-method text-nowrap small fw-semibold text-uppercase py-1 px-2">Method</th>
								<th class="col-created text-nowrap small fw-semibold text-uppercase py-1 px-2">Created</th>
								<th class="actions text-nowrap small fw-semibold text-uppercase py-1 px-2 text-center d-none">Actions</th>
							</tr>
						</thead>
						<tbody>
							{% for tx in transactions|default([]) %}
								<tr data-id="{{ tx.id }}" data-token="{{ csrf_token('transaction_action_' ~ tx.id) }}">
									<td class="col-id align-middle py-1 px-2" style="width:8%">{{ tx.id }}</td>
									<td class="col-buyer align-middle text-truncate py-1 px-2" style="max-width:22ch">{{ tx.user ? (tx.user.getFullName() ?? tx.user.email) : '—' }}<br><small class="text-muted">{{ tx.user ? tx.user.email : '' }}</small>
									</td>
									<td class="col-event align-middle text-truncate py-1 px-2">
										<span class="fw-semibold small">{{ tx.event ? tx.event.eventName : '—' }}</span>
									</td>
									<td class="col-amount text-end align-middle text-truncate py-1 px-2" data-order="{{ tx.totalAmount }}">
										<span class="small">₱{{ tx.totalAmount|number_format(2, '.', ',') }}</span>
									</td>
									<td class="col-status align-middle text-center py-1 px-2">
										{% set status = tx.paymentStatus %}
										{% set statusBadgeClass = status == 'paid' ? 'bg-success' : (status == 'pending' ? 'bg-warning' : (status == 'refunded' ? 'bg-secondary' : 'bg-danger')) %}
										<span class="badge {{ statusBadgeClass }} small">{{ status|upper }}</span>
									</td>
									<td class="col-method align-middle text-truncate py-1 px-2">
										<span class="small">{{ tx.paymentMethod ?? '—' }}</span>
									</td>
									<td class="col-created text-end align-middle text-truncate py-1 px-2" data-order="{{ tx.createdAt ? tx.createdAt.format('Y-m-d H:i') : '' }}">
										<span class="small">{{ tx.createdAt ? tx.createdAt.format('Y-m-d H:i') : '—' }}</span>
									</td>
									<td class="actions text-center align-middle py-1 px-2 d-none">
										<div class="d-inline-flex align-items-center gap-2">
											<button class="btn p-0 d-flex align-items-center justify-content-center rounded-3 view-transaction-btn" data-id="{{ tx.id }}" data-csrf="{{ csrf_token('transaction_action_' ~ tx.id) }}" title="View details" style="width:32px;height:32px;background-color:rgba(26,61,124,0.1);color:#1A3D7C;">
												<i class="fas fa-eye fa-sm"></i>
											</button>
											{% if isAdmin or (currentUserId and tx.createdBy and tx.createdBy.id == currentUserId) %}
												<button class="btn p-0 d-flex align-items-center justify-content-center rounded-3 delete-transaction-btn" data-id="{{ tx.id }}" data-token="{{ csrf_token('transaction_delete_' ~ tx.id) }}" data-url="{{ path('admin_transaction_delete', {'id': tx.id}) }}" title="Delete" style="width:32px;height:32px;background-color:rgba(220,53,69,0.1);color:#dc3545;">
													<i class="fas fa-trash fa-sm"></i>
												</button>
											{% endif %}
										</div>
									</td>
								</tr>
							{% else %}
								<tr>
									<td colspan="8" class="text-center py-4">
										<div class="text-muted">
											<div class="bg-light rounded-circle d-inline-flex align-items-center justify-content-center mb-2" style="width: 64px; height: 64px;">
												<i class="fas fa-exchange-alt fa-2x text-primary opacity-50"></i>
											</div>
											<h6 class="text-primary fw-semibold mb-1">No transactions yet</h6>
											<p class="text-muted small mb-2">There are no transactions to display. Use the create button to add one, or check filters.</p>
											<a href="{{ path('transaction_new') }}" class="btn btn-sm btn-primary">
												<i class="fas fa-plus me-2"></i>Create First Transaction
											</a>
										</div>
									</td>
								</tr>
							{% endfor %}
						</tbody>
					</table>
				</div>
			</div>
		</div>

		<!-- Details Modal -->
		<div class="modal fade" id="transactionDetailsModal" tabindex="-1" aria-hidden="true">
			<div class="modal-dialog modal-xl modal-dialog-centered">
				<div class="modal-content border-0 shadow-lg">
					<div class="modal-header" style="background: linear-gradient(135deg, #1A3D7C 0%, #15305A 100%); color: white;">
						<h5 class="modal-title">Transaction details</h5>
						<button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
					</div>
					<div class="modal-body p-4" id="transactionDetailsBody">
						<div class="text-center py-5">
							<div class="spinner-border text-secondary" role="status">
								<span class="visually-hidden">Loading...</span>
							</div>
							<p class="mt-2 text-muted">Loading details…</p>
						</div>
					</div>
					<div class="modal-footer justify-content-between">
						<div id="transactionActionsArea"></div>
						<button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal">Close</button>
					</div>
				</div>
			</div>
		</div>

		{# Include delete modal partial #}
		{{ include('transaction/_delete_modal.html.twig') }}

	</div>

{% endblock %}

{% block javascripts %}
	{{ parent() }}
	<script>
		(function () { // init DataTable
$(document).ready(function () { // Only initialize DataTable when there are real data rows (not the empty colspan fallback row)
var tableBody = $('#transactionTable tbody');
var hasDataRows = tableBody.find('tr').length > 0 && ! tableBody.find('tr').first().find('td').attr('colspan');

if (hasDataRows) {
var dt = $('#transactionTable').DataTable({
responsive: true,
dom: "<'row g-0'<'col-auto'l><'col-auto ms-auto'f>><'row'<'col-sm-12'tr>><'row g-0 small'<'col-auto'i><'col-auto ms-auto'p>>",
pageLength: 10,
lengthMenu: [
[
10, 25, 50, -1
],
[
10, 25, 50, 'All'
]
],
language: {
search: '',
searchPlaceholder: 'Search transactions...'
},
autoWidth: true,
scrollX: false,
columnDefs: [
{
orderable: false,
searchable: false,
targets: -1
}, {
type: 'num',
targets: 3
}, {
type: 'date',
targets: 6
}
],
order: [
[6, 'desc']
]
});

function setActionsVisible(visible) {
$('#transactionTable thead th:last-child, #transactionTable tbody td:last-child').toggleClass('d-none', ! visible);
try {
localStorage.setItem('transactions.showActions', visible ? '1' : '0');
} catch (e) {}
}

try {
var stored = localStorage.getItem('transactions.showActions');
var initialVisible = stored === '1';
$('#toggleTransactionsActions').prop('checked', initialVisible);
setActionsVisible(initialVisible);
} catch (e) {
setActionsVisible(false);
}

$('#toggleTransactionsActions').off('change').on('change', function () {
setActionsVisible($(this).is(':checked'));
});

dt.on('draw.dt responsive-display.dt responsive-resize.dt', function () {
setActionsVisible($('#toggleTransactionsActions').is(':checked'));
});
}

// click handler for details (delegated on document to survive DataTables DOM changes)
$(document).on('click', '.view-transaction-btn', function (e) {
var id = $(this).data('id');
var csrf = $(this).data('csrf');
var modal = $('#transactionDetailsModal');
$('#transactionDetailsBody').html('<div class="text-center py-5"><div class="spinner-border text-secondary" role="status"></div><p class="mt-2 text-muted">Loading details…</p></div>');
modal.modal('show');

$.ajax({
url: '/admin/transaction/' + id + '/details',
method: 'GET',
dataType: 'json'
}).done(function (resp) { // build markup
var html = '';
html += '<div class="row">';
html += '<div class="col-md-6">';
html += '<h5>Buyer</h5>';
html += '<p>' + (
resp.user.name || resp.user.email
) + '<br><small>' + resp.user.email + '</small></p>';
html += '<h5>Event</h5>';
html += '<p>' + (
resp.event.name || '—'
) + '<br><small>' + (
resp.event.date || ''
) + '</small></p>';
html += '</div>';

html += '<div class="col-md-6">';
html += '<h5>Payment</h5>';
html += '<p><strong>Amount:</strong> ₱' + resp.payment.amount + '</p>';
html += '<p><strong>Status:</strong> ' + resp.payment.status + '</p>';
html += '<p><strong>Method:</strong> ' + (
resp.payment.method || '—'
) + '</p>';
html += '<p><strong>Reference:</strong> ' + (
resp.payment.reference || '—'
) + '</p>';
html += '</div>';

html += '<div class="col-12 mt-3">';
html += '<h5>Tickets</h5>';
html += '<div class="table-responsive"><table class="table table-sm"><thead><tr><th>Type</th><th>Qty</th><th>Price</th><th>Code</th></tr></thead><tbody>';
resp.tickets.forEach(function (t) {
html += '<tr><td>' + t.ticketType + '</td><td>' + t.quantity + '</td><td>₱' + t.price + '</td><td>' + (
t.code || ''
) + '</td></tr>';
});
html += '</tbody></table></div>';
html += '</div>';

// QR Codes section
if (resp.ticketPurchases && resp.ticketPurchases.length > 0) {
html += '<div class="col-12 mt-3">';
html += '<h5><i class="fas fa-qrcode me-2"></i>E-Tickets & QR Codes</h5>';
html += '<div class="row g-3">';
resp.ticketPurchases.forEach(function (purchase) {
html += '<div class="col-md-4 col-lg-3">';
html += '<div class="p-3 border rounded" style="background:#f8f9fa; height: 100%;">';
html += '<div class="mb-2 fw-semibold" style="color:#1A3D7C;">' + (
purchase.ticketType || 'Ticket'
) + '</div>';
html += '<div class="mb-2 small text-muted">Code: ' + (
purchase.uniqueCode || ''
) + '</div>';
if (purchase.qrCode) {
var qrSrc = purchase.qrCode.startsWith('data:') ? purchase.qrCode : 'data:image/png;base64,' + purchase.qrCode;
html += '<div class="text-center"><img src="' + qrSrc + '" alt="QR Code" style="width: 150px;"></div>';
} else {
html += '<div class="text-muted small">QR not available</div>';
} html += '</div>';
html += '</div>';
});
html += '</div>';
html += '</div>';
}
html += '</div>';

$('#transactionDetailsBody').html(html);

// actions (add data attributes so delegated handlers can pick them up)
var actions = '';
if (resp.payment.status !== 'paid') {
actions += '<button id="btnMarkPaid" class="btn btn-success me-2" data-id="' + id + '" data-csrf="' + csrf + '">Mark as Paid</button>';
}
if (resp.payment.status !== 'refunded') {
actions += '<button id="btnRefund" class="btn btn-warning text-dark" data-id="' + id + '" data-csrf="' + csrf + '">Mark Refunded</button>';
}

$('#transactionActionsArea').html(actions);

}).fail(function (jqXHR, textStatus, errorThrown) {
console.log('AJAX Error:', jqXHR.status, textStatus, errorThrown);
if (jqXHR.status === 401 || jqXHR.status === 403) {
$('#transactionDetailsBody').html('<div class="text-center py-5 text-danger">Access denied. Please ensure you are logged in as an admin.</div>');
} else {
$('#transactionDetailsBody').html('<div class="text-center py-5 text-danger">Failed to load details (Error: ' + jqXHR.status + ')</div>');
}
$('#transactionActionsArea').html('');
});
});

// click handler for delete - open modal and set form action/token
$(document).on('click', '.delete-transaction-btn', function (e) {
e.preventDefault();
var btn = $(this);
var url = btn.data('url');
var token = btn.data('token');
// set form action and token
$('#transactionDeleteForm').attr('action', url);
$('#transactionDeleteToken').val(token);
// show modal
var modal = $('#transactionDeleteModal');
if (modal.length) {
modal.modal('show');
}
});
});
// delegated handlers for modal action buttons so they work even when modal content is re-rendered
$(document).on('click', '#btnMarkPaid', function () {
var btn = $(this);
var id = btn.data('id');
var csrf = btn.data('csrf');
$.post('/admin/transaction/' + id + '/mark-paid', {
_token: csrf
}, function (data) {
if (data.ok) {
window.location.reload();
} else {
alert(data.message || 'Error');
}
}, 'json').fail(function () {
alert('Request failed');
});
});

$(document).on('click', '#btnRefund', function () {
var btn = $(this);
var id = btn.data('id');
var csrf = btn.data('csrf');
var reason = prompt('Refund reason (optional)');
$.post('/admin/transaction/' + id + '/refund', {
_token: csrf,
reason: reason
}, function (data) {
if (data.ok) {
window.location.reload();
} else {
alert(data.message || 'Error');
}
}, 'json').fail(function () {
alert('Request failed');
});
});

})();
	</script>
{% endblock %}
