{{ form_start(form, {'attr': {'class': 'needs-validation', 'enctype': 'multipart/form-data'}}) }}
<div class="card-body p-4">
	<div class="row g-4">
		<div class="col-md-6">
			<div class="mb-3">
				{{ form_label(form.org_name, 'Organizer Name', { 'label_attr': {'class': 'form-label fw-semibold', 'style': 'color: #1A3D7C;'} }) }}
				{{ form_widget(form.org_name, { 'attr': { 'class': 'form-control', 'placeholder': 'Enter organizer name', 'style': 'border-radius: 8px; border: 2px solid #e9ecef;' } }) }}
				{{ form_errors(form.org_name) }}
			</div>
			<div class="mb-3">
				{{ form_label(form.contact, 'Contact Number', { 'label_attr': {'class': 'form-label fw-semibold', 'style': 'color: #1A3D7C;'} }) }}
				{{ form_widget(form.contact, { 'attr': { 'class': 'form-control', 'placeholder': 'e.g. +63 900 000 0000', 'style': 'border-radius: 8px; border: 2px solid #e9ecef;' } }) }}
				{{ form_errors(form.contact) }}
			</div>
			<div class="mb-3">
				{{ form_label(form.email, 'Email', { 'label_attr': {'class': 'form-label fw-semibold', 'style': 'color: #1A3D7C;'} }) }}
				{{ form_widget(form.email, { 'attr': { 'class': 'form-control', 'placeholder': 'name@example.com', 'style': 'border-radius: 8px; border: 2px solid #e9ecef;' } }) }}
				{{ form_errors(form.email) }}
			</div>
		</div>
		<div class="col-md-6">
			<div class="mb-3">
				{{ form_label(form.contactPerson, 'Contact Person', { 'label_attr': {'class': 'form-label fw-semibold', 'style': 'color: #1A3D7C;'} }) }}
				{{ form_widget(form.contactPerson, { 'attr': { 'class': 'form-control', 'placeholder': 'Enter contact person', 'style': 'border-radius: 8px; border: 2px solid #e9ecef;' } }) }}
				{{ form_errors(form.contactPerson) }}
			</div>
			<div class="mb-3">
				{{ form_label(form.description, 'Description', { 'label_attr': {'class': 'form-label fw-semibold', 'style': 'color: #1A3D7C;'} }) }}
				{{ form_widget(form.description, { 'attr': { 'class': 'form-control', 'rows': '4', 'placeholder': 'Describe the organizer', 'style': 'border-radius: 8px; border: 2px solid #e9ecef; resize: vertical;' } }) }}
				{{ form_errors(form.description) }}
			</div>
			<div class="mb-3">
				{{ form_label(form.logoFile, 'Upload Logo', { 'label_attr': {'class': 'form-label fw-semibold', 'style': 'color: #1A3D7C;'} }) }}
				{{ form_widget(form.logoFile, { 'attr': { 'class': 'form-control', 'style': 'border-radius: 8px; border: 2px solid #e9ecef;' } }) }}
				{{ form_errors(form.logoFile) }}
			</div>
		</div>
	</div>
</div>
<div class="card-footer bg-light" style="border-top: 1px solid #e9ecef; border-radius: 0 0 12px 12px;">
	<div class="d-flex justify-content-end gap-3">
		<a href="{{ path('app_organizer_index') }}" class="btn btn-outline-secondary" style="border-radius: 8px; padding: 10px 20px; font-weight: 500;">
			<i class="fas fa-times me-2"></i>Cancel
		</a>
		<button type="submit" class="btn" style="background-color: #1A3D7C; color: white; border: none; border-radius: 8px; padding: 10px 20px; font-weight: 600;">
			<i class="fas fa-save me-2"></i>
			{{ button_label|default('Save Organizer') }}
		</button>
	</div>
</div>
{{ form_end(form) }}
