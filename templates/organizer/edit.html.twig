{% extends 'admin/base.html.twig' %}

{% block title %}Edit Organizer
{% endblock %}

{% block body %}
	<div class="content-wrapper">
		<div class="d-flex justify-content-between align-items-center mb-4">
			<h1 class="h3 mb-0" style="color: #1A3D7C">
				<i class="fas fa-user-edit me-2" style="color:#F9B233"></i>Edit Organizer</h1>
			<div class="d-flex gap-2">
				<a href="{{ path('app_organizer_show', {'id': organizer.id}) }}" class="btn btn-outline-info" style="border-radius: 8px; padding: 10px 20px; font-weight: 500;">
					<i class="fas fa-eye me-2"></i>View
				</a>
			</div>

		</div>
		<div class="card shadow-sm" style="border-radius: 12px; overflow: hidden;">
			<div class="card-header" style="background-color: #1A3D7C; color: white; border: none;">
				<h3 class="card-title mb-0">
					<i class="fas fa-id-card me-2"></i>Organizer Details</h3>
			</div>
			{{ include('organizer/_form.html.twig', {'button_label': 'Update Organizer'}) }}
		</div>
	</div>
{% endblock %}
